+/**
+ * @ingroup system-tests-tc
+ *
+ * Verify ACK filter drops are credited to the per-reason stats map under
+ * the ACK_FILTER_DROP key, and that GetStats().nDroppedPacketsAfterDequeue
+ * and GetAckFilterDrops() agree on the count. The cascade at
+ * queue-disc.cc:336-338 currently hardcodes the drop reason to
+ * INTERNAL_QUEUE_DROP, so the per-reason ACK_FILTER_DROP credit is lost
+ * even though GetAckFilterDrops() (a dedicated counter) reads correctly.
+ */
+class FqCobaltQueueDiscAckFilterDropReason : public TestCase
+{
+  public:
+    FqCobaltQueueDiscAckFilterDropReason()
+        : TestCase("FqCobaltQueueDisc ACK filter drops credited to ACK_FILTER_DROP per-reason stats")
+    {
+    }
+
+  private:
+    void DoRun() override
+    {
+        // Workload mirrors FqCobaltQueueDiscAckFilter sub-case 2: four
+        // monotonic same-flow ACKs under conservative 2-eligible threshold
+        // collapse to two survivors, producing two ACK filter drops.
+        const Ipv4Address srcA("10.1.1.1");
+        const Ipv4Address dstA("10.2.2.2");
+        constexpr uint16_t kSport = 1024;
+        constexpr uint16_t kDport = 80;
+
+        Ptr<FqCobaltQueueDisc> q =
+            CreateObjectWithAttributes<FqCobaltQueueDisc>("EnableAckFilter", BooleanValue(true));
+        q->SetQuantum(1514);
+        q->Initialize();
+        q->Enqueue(MakeAckOnlyItem(srcA, dstA, kSport, kDport, 100));
+        q->Enqueue(MakeAckOnlyItem(srcA, dstA, kSport, kDport, 200));
+        q->Enqueue(MakeAckOnlyItem(srcA, dstA, kSport, kDport, 300));
+        q->Enqueue(MakeAckOnlyItem(srcA, dstA, kSport, kDport, 400));
+
+        NS_TEST_ASSERT_MSG_GT(q->GetAckFilterDrops(),
+                              0u,
+                              "Test setup must trigger at least one ACK filter drop");
+
+        const QueueDisc::Stats stats = q->GetStats();
+        const auto& reasonMap = stats.nDroppedPacketsAfterDequeue;
+        const std::size_t keyPresent =
+            reasonMap.count(FqCobaltQueueDisc::ACK_FILTER_DROP);
+        NS_TEST_ASSERT_MSG_EQ(keyPresent,
+                              1u,
+                              "ACK_FILTER_DROP key must be present in per-reason stats map");
+        const uint32_t perReasonCount =
+            (keyPresent == 1u) ? reasonMap.at(FqCobaltQueueDisc::ACK_FILTER_DROP) : 0u;
+        NS_TEST_ASSERT_MSG_EQ(perReasonCount,
+                              q->GetAckFilterDrops(),
+                              "Per-reason stats must equal GetAckFilterDrops()");
+        NS_TEST_ASSERT_MSG_GT(perReasonCount,
+                              0u,
+                              "Expected at least one ACK_FILTER_DROP credit");
+        Simulator::Destroy();
+    }
+};

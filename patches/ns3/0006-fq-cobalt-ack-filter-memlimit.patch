+/**
+ * @ingroup system-tests-tc
+ *
+ * Verify that the ACK filter scan is skipped when the inner CobaltQueueDisc
+ * rejects the arriving trigger (queue-full at the per-flow MaxSize). The
+ * pre-fix path called ScanAndDropRedundant unconditionally, walking the
+ * flow's queue with the previous tail as the trigger source for cached
+ * SACK / TS / ECE-CWR fields but with the rejected arrival's newAckNum +
+ * newKey — a mixed-up trigger.
+ *
+ * Two sub-cases cover both filter modes:
+ *   - Aggressive: three same-flow ACKs [ack=10, ack=10, ack=20] +
+ *     MaxSize=2. Pre-fix the buggy scan drops ACK1 via the aggressive
+ *     consecutive-shortcut (numFound==1 + nextPos==tail + flag-match).
+ *   - Conservative: four same-flow ACKs [10, 10, 10, 20] + MaxSize=3.
+ *     Pre-fix the buggy scan finds two eligibles in the walk over
+ *     [ACK1, ACK2] (ACK3=tail) and the conservative numFound>1 branch
+ *     drops the first-saved (ACK1).
+ *
+ * In both sub-cases, post-fix the scan is skipped entirely on Cobalt
+ * rejection and the queue's older same-flow ACKs survive.
+ */
+class FqCobaltQueueDiscScanSkipsCobaltRejection : public TestCase
+{
+  public:
+    FqCobaltQueueDiscScanSkipsCobaltRejection()
+        : TestCase("ACK filter scan is skipped when inner Cobalt rejects "
+                   "the trigger (no stale-tail spurious drop)")
+    {
+    }
+
+    ~FqCobaltQueueDiscScanSkipsCobaltRejection() override = default;
+
+  private:
+    void DoRun() override
+    {
+        const Ipv4Address srcA("10.1.1.1");
+        const Ipv4Address dstA("10.2.2.2");
+        constexpr uint16_t kSport = 1024;
+        constexpr uint16_t kDport = 80;
+
+        // Aggressive sub-case. EnableAckFilterAggressive=true, MaxSize=2.
+        // Three same-flow ACKs [ack=10, ack=10, ack=20]. Step 1: ACK1
+        // enqueued, scan walks empty. Step 2: ACK2 enqueued, scan walks
+        // [ACK1]; duplicate-ACK SACK gate PRESERVES ACK1. Step 3: ACK3
+        // (ack=20) enqueue, inner Cobalt rejects (queue full). Pre-fix
+        // the buggy scan walks [ACK1] with tail=ACK2, finds 1 eligible,
+        // aggressive consecutive-shortcut (eligAckPos+1==tail and ECE/CWR
+        // flags match) DROPs ACK1. Fixed: scan skipped, ACK1 survives.
+        {
+            Ptr<FqCobaltQueueDisc> q = CreateObjectWithAttributes<FqCobaltQueueDisc>(
+                "EnableAckFilter", BooleanValue(true),
+                "EnableAckFilterAggressive", BooleanValue(true),
+                "MaxSize", QueueSizeValue(QueueSize("2p")));
+            q->SetQuantum(1514);
+            q->Initialize();
+
+            q->Enqueue(MakeAckOnlyItem(srcA, dstA, kSport, kDport, 10));
+            q->Enqueue(MakeAckOnlyItem(srcA, dstA, kSport, kDport, 10));
+            q->Enqueue(MakeAckOnlyItem(srcA, dstA, kSport, kDport, 20));
+
+            NS_TEST_ASSERT_MSG_EQ(q->GetNPackets(),
+                                  2u,
+                                  "Aggressive: both ACK1 (10) and ACK2 (10) must "
+                                  "survive; the Cobalt-rejected ACK3 (20) must not "
+                                  "trigger a stale-tail aggressive-consecutive drop.");
+            NS_TEST_ASSERT_MSG_EQ(q->GetAckFilterDrops(),
+                                  0u,
+                                  "Aggressive: no ACK filter drops should be credited "
+                                  "when the trigger arrival was Cobalt-rejected.");
+            Simulator::Destroy();
+        }
+
+        // Conservative sub-case. EnableAckFilterAggressive=false (default),
+        // MaxSize=3. Four same-flow ACKs [10, 10, 10, 20]. Steps 1-3:
+        // duplicates preserved by SACK gate; queue grows to [ACK1,
+        // ACK2, ACK3]. Step 4: ACK4 (ack=20) enqueue, inner Cobalt
+        // rejects (queue full at 3). Pre-fix the buggy scan walks
+        // [ACK1, ACK2] with tail=ACK3; both eligibles found
+        // (cumul=10 < newAckNum=20, comparator==0 + cumul mismatch =>
+        // droppable), numFound>1 triggers conservative drop of the
+        // first-saved (ACK1, closest-to-head). Fixed: scan skipped,
+        // ACK1 survives.
+        {
+            Ptr<FqCobaltQueueDisc> q = CreateObjectWithAttributes<FqCobaltQueueDisc>(
+                "EnableAckFilter", BooleanValue(true),
+                "EnableAckFilterAggressive", BooleanValue(false),
+                "MaxSize", QueueSizeValue(QueueSize("3p")));
+            q->SetQuantum(1514);
+            q->Initialize();
+
+            q->Enqueue(MakeAckOnlyItem(srcA, dstA, kSport, kDport, 10));
+            q->Enqueue(MakeAckOnlyItem(srcA, dstA, kSport, kDport, 10));
+            q->Enqueue(MakeAckOnlyItem(srcA, dstA, kSport, kDport, 10));
+            q->Enqueue(MakeAckOnlyItem(srcA, dstA, kSport, kDport, 20));
+
+            NS_TEST_ASSERT_MSG_EQ(q->GetNPackets(),
+                                  3u,
+                                  "Conservative: all three duplicate-cumulative ACKs "
+                                  "(10, 10, 10) must survive; the Cobalt-rejected "
+                                  "ACK4 (20) must not trigger a stale-tail conservative "
+                                  "two-eligible drop.");
+            NS_TEST_ASSERT_MSG_EQ(q->GetAckFilterDrops(),
+                                  0u,
+                                  "Conservative: no ACK filter drops should be credited "
+                                  "when the trigger arrival was Cobalt-rejected.");
+            Simulator::Destroy();
+        }
+    }
+};
+
+/**
+ * @ingroup system-tests-tc
+ *
+ * Verify the EnableAckFilter contract: default-off byte-equivalence,
+ * monotonic-ACK collapse to a single survivor, SACK preservation under
+ * conservative mode, and cross-flow isolation.
+ */
+class FqCobaltQueueDiscAckFilter : public TestCase
+{
+  public:
+    FqCobaltQueueDiscAckFilter();
+    ~FqCobaltQueueDiscAckFilter() override;
+
+  private:
+    void DoRun() override;
+};
+
+FqCobaltQueueDiscAckFilter::FqCobaltQueueDiscAckFilter()
+    : TestCase("Test EnableAckFilter drops older redundant ACKs")
+{
+}
+
+FqCobaltQueueDiscAckFilter::~FqCobaltQueueDiscAckFilter()
+{
+}
+
+void
+FqCobaltQueueDiscAckFilter::DoRun()
+{
+    const Ipv4Address srcA("10.1.1.1");
+    const Ipv4Address dstA("10.2.2.2");
+    const Ipv4Address srcB("10.1.1.3");
+    constexpr uint16_t kSport = 1024;
+    constexpr uint16_t kDport = 80;
+
+    // Sub-case 1: default-off byte-equivalence. With EnableAckFilter false,
+    // three same-5-tuple ACKs all enqueue and the filter counter stays zero.
+    {
+        Ptr<FqCobaltQueueDisc> q =
+            CreateObjectWithAttributes<FqCobaltQueueDisc>("EnableAckFilter", BooleanValue(false));
+        q->SetQuantum(1514);
+        q->Initialize();
+        q->Enqueue(MakeAckOnlyItem(srcA, dstA, kSport, kDport, 100));
+        q->Enqueue(MakeAckOnlyItem(srcA, dstA, kSport, kDport, 200));
+        q->Enqueue(MakeAckOnlyItem(srcA, dstA, kSport, kDport, 300));
+        NS_TEST_ASSERT_MSG_EQ(q->GetNPackets(),
+                              3u,
+                              "Filter-off must enqueue all three same-flow ACKs");
+        NS_TEST_ASSERT_MSG_EQ(q->GetAckFilterDrops(),
+                              0u,
+                              "Filter-off must not increment the filter drop counter");
+        Simulator::Destroy();
+    }
+
+    // Sub-case 2: four monotonic same-flow ACKs under the conservative
+    // 2-eligible threshold. Per-arrival accounting (Linux cake_ack_filter
+    // at sch_cake.c:1336-1356 requires numFound > 1 before a drop):
+    //   - enq 100: scan 0 prior items -> 0 eligibles, no drop. Queue=[100].
+    //   - enq 200: scan {100} -> 1 eligible, no drop. Queue=[100,200].
+    //   - enq 300: scan {100,200} -> 2 eligibles, drop first-saved
+    //     (100, closest to head). Queue=[200,300], drops=1.
+    //   - enq 400: scan {200,300} -> 2 eligibles, drop first-saved
+    //     (200). Queue=[300,400], drops=2.
+    // Expected survivors: 300 (head) and 400 (tail). Filter drop counter
+    // accumulates to 2.
+    {
+        Ptr<FqCobaltQueueDisc> q =
+            CreateObjectWithAttributes<FqCobaltQueueDisc>("EnableAckFilter", BooleanValue(true));
+        q->SetQuantum(1514);
+        q->Initialize();
+        q->Enqueue(MakeAckOnlyItem(srcA, dstA, kSport, kDport, 100));
+        q->Enqueue(MakeAckOnlyItem(srcA, dstA, kSport, kDport, 200));
+        q->Enqueue(MakeAckOnlyItem(srcA, dstA, kSport, kDport, 300));
+        q->Enqueue(MakeAckOnlyItem(srcA, dstA, kSport, kDport, 400));
+        NS_TEST_ASSERT_MSG_EQ(q->GetNPackets(),
+                              2u,
+                              "Four monotonic same-flow ACKs collapse to two "
+                              "survivors under conservative 2-eligible threshold");
+        NS_TEST_ASSERT_MSG_EQ(q->GetAckFilterDrops(),
+                              2u,
+                              "Two older ACKs (100, 200) must be charged to "
+                              "the filter counter; closest-to-head wins each scan");
+        Ptr<QueueDiscItem> head = q->Dequeue();
+        NS_TEST_ASSERT_MSG_NE(head, nullptr, "Dequeue must yield the head survivor");
+        Ptr<const Ipv4QueueDiscItem> ipv4 = DynamicCast<const Ipv4QueueDiscItem>(head);
+        NS_TEST_ASSERT_MSG_NE(ipv4, nullptr, "Survivor must be an Ipv4QueueDiscItem");
+        Ptr<Packet> pkt = ipv4->GetPacket()->Copy();
+        TcpHeader hdr;
+        pkt->RemoveHeader(hdr);
+        NS_TEST_ASSERT_MSG_EQ(hdr.GetAckNumber().GetValue(),
+                              300u,
+                              "Head survivor must carry ackNum=300 (200 was "
+                              "dropped on the 400-arrival scan)");
+        Simulator::Destroy();
+    }
+
+    // Sub-case 3: SACK-bearing trigger drops a queued plain ACK whose
+    // (empty) SACK report is trivially covered by the trigger's SACK
+    // block. Mirrors Linux cake_tcph_sack_compare (sch_cake.c:1318-1330):
+    // the queued ACK carries no selective-acknowledgement information,
+    // so dropping it loses nothing. Two plain queued ACKs are required
+    // so the trigger's walk finds 2 eligibles (sch_cake.c:1336-1356).
+    {
+        Ptr<FqCobaltQueueDisc> q =
+            CreateObjectWithAttributes<FqCobaltQueueDisc>("EnableAckFilter", BooleanValue(true));
+        q->SetQuantum(1514);
+        q->Initialize();
+        q->Enqueue(MakeAckOnlyItem(srcA, dstA, kSport, kDport, 100));
+        q->Enqueue(MakeAckOnlyItem(srcA, dstA, kSport, kDport, 150));
+        q->Enqueue(MakeAckOnlyItemWithSack(srcA, dstA, kSport, kDport, 200));
+        NS_TEST_ASSERT_MSG_EQ(q->GetNPackets(),
+                              2u,
+                              "SACK-bearing trigger drops first-saved plain ACK "
+                              "(ackNum=100) under 2-eligible threshold");
+        NS_TEST_ASSERT_MSG_EQ(q->GetAckFilterDrops(),
+                              1u,
+                              "Exactly one drop: first-saved (closest-to-head) "
+                              "plain ACK is the victim when trigger SACK covers it");
+        Simulator::Destroy();
+    }
+
+    // Sub-case 4: cross-flow isolation. The filter operates only within a
+    // 5-tuple; an unrelated flow-B ACK is not affected when older flow-A
+    // ACKs are suppressed by a newer flow-A ACK. Two flow-A ACKs are
+    // primed before the flow-B insertion so that the final flow-A
+    // trigger's walk finds 2 same-flow eligibles
+    // (conservative 2-eligible threshold per sch_cake.c:1336-1356).
+    {
+        Ptr<FqCobaltQueueDisc> q =
+            CreateObjectWithAttributes<FqCobaltQueueDisc>("EnableAckFilter", BooleanValue(true));
+        q->SetQuantum(1514);
+        q->Initialize();
+        q->Enqueue(MakeAckOnlyItem(srcA, dstA, kSport, kDport, 100));
+        q->Enqueue(MakeAckOnlyItem(srcA, dstA, kSport, kDport, 150));
+        q->Enqueue(MakeAckOnlyItem(srcB, dstA, kSport, kDport, 100));
+        q->Enqueue(MakeAckOnlyItem(srcA, dstA, kSport, kDport, 200));
+        NS_TEST_ASSERT_MSG_EQ(q->GetNPackets(),
+                              3u,
+                              "Cross-flow isolation: flow-B ACK must survive; "
+                              "first-saved flow-A ACK (100) is dropped on the "
+                              "flow-A trigger");
+        NS_TEST_ASSERT_MSG_EQ(q->GetAckFilterDrops(),
+                              1u,
+                              "Only the first-saved flow-A ACK must be dropped");
+        // Per-reason stats parity: the ACK_FILTER_DROP key must be
+        // present and its credit must equal GetAckFilterDrops(). Guard
+        // the .at() access with a ternary because NS_TEST_ASSERT_MSG_EQ
+        // does not abort on failure.
+        const QueueDisc::Stats stats = q->GetStats();
+        const auto& reasonMap = stats.nDroppedPacketsAfterDequeue;
+        const std::size_t keyPresent =
+            reasonMap.count(FqCobaltQueueDisc::ACK_FILTER_DROP);
+        NS_TEST_ASSERT_MSG_EQ(keyPresent,
+                              1u,
+                              "ACK_FILTER_DROP key must be present in per-reason stats map");
+        const uint32_t perReasonCount =
+            (keyPresent == 1u) ? reasonMap.at(FqCobaltQueueDisc::ACK_FILTER_DROP) : 0u;
+        NS_TEST_ASSERT_MSG_EQ(perReasonCount,
+                              q->GetAckFilterDrops(),
+                              "Per-reason stats must equal GetAckFilterDrops()");
+        Simulator::Destroy();
+    }
+}
+
+/**
+ * @ingroup system-tests-tc
+ *
+ * Verify the MemLimit Linux-faithful eviction contract: arrivals always
+ * succeed (no pre-enqueue admission gate), but the queue's byte total
+ * is bounded by the configured MemLimit via a post-everything eviction
+ * loop that drops one item per iteration from the head of the longest
+ * flow queue. Mirrors Linux @c cake_enqueue at @c sch_cake.c:1949-1962
+ * (`while (q->buffer_used > q->buffer_limit) cake_drop(sch)`).
+ */
+class FqCobaltQueueDiscMemLimit : public TestCase
+{
+  public:
+    FqCobaltQueueDiscMemLimit();
+    ~FqCobaltQueueDiscMemLimit() override;
+
+  private:
+    void DoRun() override;
+};
+
+FqCobaltQueueDiscMemLimit::FqCobaltQueueDiscMemLimit()
+    : TestCase("Test MemLimit byte-counted post-everything eviction (Linux-faithful)")
+{
+}
+
+FqCobaltQueueDiscMemLimit::~FqCobaltQueueDiscMemLimit()
+{
+}
+
+void
+FqCobaltQueueDiscMemLimit::DoRun()
+{
+    constexpr uint32_t kPayload = 1000;
+    constexpr uint32_t kArrivals = 20;
+
+    auto buildItem = [](Ipv4Address src, uint32_t payload) {
+        Ptr<Packet> p = Create<Packet>(payload);
+        Ipv4Header ip;
+        ip.SetSource(src);
+        ip.SetDestination(Ipv4Address("10.2.2.2"));
+        ip.SetProtocol(17); // UDP
+        ip.SetPayloadSize(p->GetSize());
+        return Create<Ipv4QueueDiscItem>(p, Address(), 0x0800, ip);
+    };
+
+    // Sub-case 1: byte-cap eviction. Saturate with arrivals whose
+    // aggregate would exceed kCapBytes; verify that ALL arrivals are
+    // admitted (no pre-enqueue rejection — Linux has no admission gate),
+    // queued bytes are bounded at the cap via post-everything eviction,
+    // and the per-reason stats credit MEMLIMIT_DROP.
+    {
+        constexpr uint32_t kCapBytes = 5000;
+        Ptr<FqCobaltQueueDisc> q =
+            CreateObjectWithAttributes<FqCobaltQueueDisc>("MemLimit", UintegerValue(kCapBytes));
+        q->SetQuantum(1514);
+        q->Initialize();
+
+        const Ipv4Address srcA("10.1.1.1");
+        uint32_t admitted = 0;
+        for (uint32_t i = 0; i < kArrivals; ++i)
+        {
+            if (q->Enqueue(buildItem(srcA, kPayload)))
+            {
+                ++admitted;
+            }
+        }
+        NS_TEST_ASSERT_MSG_EQ(admitted,
+                              kArrivals,
+                              "All arrivals must succeed — Linux-faithful MemLimit "
+                              "has no pre-enqueue admission gate. Over-cap admissions "
+                              "drive the post-everything eviction loop instead.");
+        NS_TEST_ASSERT_MSG_LT_OR_EQ(q->GetNBytes(),
+                                    kCapBytes,
+                                    "Queued bytes must be bounded by the cap after "
+                                    "post-everything eviction (each over-cap arrival "
+                                    "drives eviction of one item per loop iteration).");
+        const QueueDisc::Stats stats = q->GetStats();
+        const auto& reasonMap = stats.nDroppedPacketsAfterDequeue;
+        const std::size_t keyPresent = reasonMap.count(FqCobaltQueueDisc::MEMLIMIT_DROP);
+        NS_TEST_ASSERT_MSG_EQ(keyPresent,
+                              1u,
+                              "MEMLIMIT_DROP key must be present in per-reason stats "
+                              "when memlimit eviction fires.");
+        const uint32_t evictions =
+            (keyPresent == 1u) ? reasonMap.at(FqCobaltQueueDisc::MEMLIMIT_DROP) : 0u;
+        NS_TEST_ASSERT_MSG_GT(evictions,
+                              0u,
+                              "Per-reason MEMLIMIT_DROP count must be > 0 under "
+                              "saturation against the cap.");
+        Simulator::Destroy();
+    }
+
+    // Sub-case 2: independence from the packet-count MaxSize. MemLimit=0
+    // (the sentinel) disables the byte eviction; the parent's existing
+    // packet-count MaxSize remains the only constraint, so all arrivals
+    // enqueue and no MEMLIMIT_DROP credits accrue.
+    {
+        Ptr<FqCobaltQueueDisc> q =
+            CreateObjectWithAttributes<FqCobaltQueueDisc>("MemLimit", UintegerValue(0));
+        q->SetQuantum(1514);
+        q->Initialize();
+
+        const Ipv4Address srcA("10.1.1.1");
+        for (uint32_t i = 0; i < kArrivals; ++i)
+        {
+            const bool ok = q->Enqueue(buildItem(srcA, kPayload));
+            NS_TEST_ASSERT_MSG_EQ(ok, true, "MemLimit=0 must accept all arrivals");
+        }
+        NS_TEST_ASSERT_MSG_EQ(q->GetNPackets(),
+                              kArrivals,
+                              "All arrivals must remain enqueued when MemLimit is "
+                              "disabled (no eviction).");
+        const QueueDisc::Stats stats = q->GetStats();
+        const auto& reasonMap = stats.nDroppedPacketsAfterDequeue;
+        const std::size_t keyPresent = reasonMap.count(FqCobaltQueueDisc::MEMLIMIT_DROP);
+        const uint32_t evictions =
+            (keyPresent == 1u) ? reasonMap.at(FqCobaltQueueDisc::MEMLIMIT_DROP) : 0u;
+        NS_TEST_ASSERT_MSG_EQ(evictions,
+                              0u,
+                              "MEMLIMIT_DROP credit must stay zero when MemLimit=0.");
+        Simulator::Destroy();
+    }
+
+    // Sub-case 3: eviction picks the longest flow, not the arrival's
+    // flow. Mirrors Linux cake_drop selecting the head of the longest
+    // queue across all flows (`overflow_heap[0]`). Setup: prime flow A
+    // (10.1.1.1) with several large packets, then flow B (10.1.1.2)
+    // with one small packet that brings the disc over cap. The flow
+    // A backlog dominates by byte count, so eviction must drop from A
+    // — flow B's single packet must survive.
+    {
+        constexpr uint32_t kCapBytes = 3000;
+        Ptr<FqCobaltQueueDisc> q =
+            CreateObjectWithAttributes<FqCobaltQueueDisc>("MemLimit", UintegerValue(kCapBytes));
+        q->SetQuantum(1514);
+        q->Initialize();
+
+        const Ipv4Address srcA("10.1.1.1");
+        const Ipv4Address srcB("10.1.1.2");
+
+        // Prime flow A with 4 × 800 = 3200 bytes (already above cap by 200).
+        for (uint32_t i = 0; i < 4; ++i)
+        {
+            q->Enqueue(buildItem(srcA, 800));
+        }
+        // Arrival on flow B with 100 bytes (small; flow B has the smaller
+        // backlog after this arrival).
+        q->Enqueue(buildItem(srcB, 100));
+
+        NS_TEST_ASSERT_MSG_LT_OR_EQ(q->GetNBytes(),
+                                    kCapBytes,
+                                    "After eviction, total byte count must be at or "
+                                    "below the cap.");
+
+        // Walk the inner flow queues; flow B's 100-byte item must still be
+        // present. Discover it by scanning each FqCobaltFlow and checking
+        // for an item whose source matches srcB.
+        bool flowBSurvived = false;
+        for (uint32_t i = 0; i < q->GetNQueueDiscClasses(); ++i)
+        {
+            Ptr<QueueDisc> inner = q->GetQueueDiscClass(i)->GetQueueDisc();
+            if (!inner || inner->GetNPackets() == 0)
+            {
+                continue;
+            }
+            Ptr<QueueBase> internalBase = inner->GetInternalQueue(0);
+            Ptr<Queue<QueueDiscItem>> internal =
+                DynamicCast<Queue<QueueDiscItem>>(internalBase);
+            if (!internal)
+            {
+                continue;
+            }
+            for (auto it = internal->Begin(); it != internal->End(); ++it)
+            {
+                Ptr<const Ipv4QueueDiscItem> ipv4 =
+                    DynamicCast<const Ipv4QueueDiscItem>(*it);
+                if (ipv4 && ipv4->GetHeader().GetSource() == srcB)
+                {
+                    flowBSurvived = true;
+                    break;
+                }
+            }
+            if (flowBSurvived)
+            {
+                break;
+            }
+        }
+        NS_TEST_ASSERT_MSG_EQ(flowBSurvived,
+                              true,
+                              "Eviction must drop from the longest flow (A), not the "
+                              "arrival's flow (B). The Linux cake_drop policy is "
+                              "'head of the longest queue' (overflow_heap[0]).");
+        Simulator::Destroy();
+    }
+}

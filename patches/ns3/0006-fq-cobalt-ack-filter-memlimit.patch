+class AckFilterFrameworkInvariantTest : public TestCase
+{
+  public:
+    AckFilterFrameworkInvariantTest()
+        : TestCase("FqCobalt ACK filter: outer-stats invariant under "
+                   "saturating same-flow ACK burst (regression for v1.0 "
+                   "drain-and-refill assertion at queue-disc.cc:896)")
+    {
+    }
+
+  private:
+    void DoRun() override;
+
+    /// Build an ACK-only Ipv4QueueDiscItem with the given 5-tuple +
+    /// cumulative ACK number. Delegates to the existing MakeAckOnlyItem
+    /// free helper already defined in this file.
+    Ptr<Ipv4QueueDiscItem> MakeAck(Ipv4Address src,
+                                   Ipv4Address dst,
+                                   uint16_t srcPort,
+                                   uint16_t dstPort,
+                                   uint32_t ackNum);
+
+    /// Build a TCP DATA segment (PSH+ACK with payload) on the same
+    /// 5-tuple. Used to create survivors that ScanAndDropRedundant
+    /// must re-enqueue (drain-and-refill code path).
+    Ptr<Ipv4QueueDiscItem> MakeData(Ipv4Address src,
+                                    Ipv4Address dst,
+                                    uint16_t srcPort,
+                                    uint16_t dstPort,
+                                    uint32_t seqNum,
+                                    uint32_t payloadSize);
+};
+
+Ptr<Ipv4QueueDiscItem>
+AckFilterFrameworkInvariantTest::MakeAck(Ipv4Address src,
+                                         Ipv4Address dst,
+                                         uint16_t srcPort,
+                                         uint16_t dstPort,
+                                         uint32_t ackNum)
+{
+    return MakeAckOnlyItem(src, dst, srcPort, dstPort, ackNum);
+}
+
+Ptr<Ipv4QueueDiscItem>
+AckFilterFrameworkInvariantTest::MakeData(Ipv4Address src,
+                                          Ipv4Address dst,
+                                          uint16_t srcPort,
+                                          uint16_t dstPort,
+                                          uint32_t seqNum,
+                                          uint32_t payloadSize)
+{
+    TcpHeader tcp;
+    tcp.SetSourcePort(srcPort);
+    tcp.SetDestinationPort(dstPort);
+    tcp.SetSequenceNumber(SequenceNumber32(seqNum));
+    tcp.SetAckNumber(SequenceNumber32(1));
+    // PSH|ACK with payload makes IsAckCandidate return false (the
+    // candidate predicate excludes anything that carries data).
+    tcp.SetFlags(TcpHeader::PSH | TcpHeader::ACK);
+    tcp.SetWindowSize(65535);
+
+    Ptr<Packet> p = Create<Packet>(payloadSize);
+    p->AddHeader(tcp);
+
+    Ipv4Header ip;
+    ip.SetSource(src);
+    ip.SetDestination(dst);
+    ip.SetProtocol(6);
+    ip.SetPayloadSize(p->GetSize());
+    return Create<Ipv4QueueDiscItem>(p, Address(), 0x0800, ip);
+}
+
+void
+AckFilterFrameworkInvariantTest::DoRun()
+{
+    // Build a FqCobaltQueueDisc with the ACK filter enabled.
+    Ptr<FqCobaltQueueDisc> q = CreateObject<FqCobaltQueueDisc>();
+    q->SetQuantum(1500);
+    q->SetAttribute("EnableAckFilter", BooleanValue(true));
+    q->Initialize();
+
+    // Mixed DATA + ACK burst on the same 5-tuple. Each ACK arrival
+    // triggers ScanAndDropRedundant which walks the inner queue and
+    // (under the v1.0 drain-and-refill model) re-enqueues every DATA
+    // survivor via inner->Enqueue. Each survivor re-enqueue fires the
+    // inner->outer PacketEnqueued trace cascade wired by
+    // AddQueueDiscClass at queue-disc.cc:653-655, inflating outer's
+    // nTotalEnqueuedPackets without a matching nTotalReceivedPackets
+    // bump. The next outer Enqueue call hits the
+    // queue-disc.cc:895-896 NS_ASSERT.
+    //
+    // Pattern: prime the queue with several DATA segments (survivors),
+    // then drive a burst of monotonically increasing ACKs on the same
+    // 5-tuple. Each ACK drops the previous queued ACK (no survivor)
+    // BUT re-enqueues every DATA segment (survivors), triggering the
+    // cascade.
+    const Ipv4Address kSrc("10.0.0.1");
+    const Ipv4Address kDst("10.0.0.2");
+    const uint16_t kSrcPort = 12345;
+    const uint16_t kDstPort = 80;
+    const uint32_t kPrimeData = 8;
+    const uint32_t kAckBurst = 20;
+
+    // Prime: 8 DATA segments on the 5-tuple (will be survivors during
+    // every subsequent ACK-triggered scan).
+    for (uint32_t i = 0; i < kPrimeData; ++i)
+    {
+        q->Enqueue(MakeData(kSrc, kDst, kSrcPort, kDstPort,
+                            1000 + i * 1000, 1000));
+    }
+
+    // ACK burst: each ACK triggers a scan that drains all 8 DATA + any
+    // queued ACK, drops same-flow older ACK, re-enqueues the 8 DATA
+    // segments. Cascade fires 8 PacketEnqueued bumps on outer per ACK.
+    for (uint32_t i = 0; i < kAckBurst; ++i)
+    {
+        q->Enqueue(MakeAck(kSrc, kDst, kSrcPort, kDstPort, 5000 + i * 100));
+    }
+
+    // Invariant check: nTotalReceivedPackets == nTotalDroppedPacketsBeforeEnqueue
+    // + nTotalEnqueuedPackets.
+    QueueDisc::Stats st = q->GetStats();
+    NS_TEST_ASSERT_MSG_EQ(st.nTotalReceivedPackets,
+                          st.nTotalDroppedPacketsBeforeEnqueue +
+                              st.nTotalEnqueuedPackets,
+                          "Outer-stats invariant violated under "
+                          "mixed DATA + ACK burst (drain-and-refill "
+                          "cascade inflated nTotalEnqueuedPackets)");
+
+    // Sanity: at least a few ACKs should have been filter-dropped
+    // (each new arrival drops the strictly-older queued ACK). Assert
+    // >= kAckBurst/4 as a robust lower bound that distinguishes
+    // "filter ran" from "filter inert".
+    NS_TEST_ASSERT_MSG_GT_OR_EQ(
+        st.nTotalDroppedPacketsAfterDequeue,
+        kAckBurst / 4,
+        "ACK filter appears inert (DroppedAfterDequeue too low)");
+}

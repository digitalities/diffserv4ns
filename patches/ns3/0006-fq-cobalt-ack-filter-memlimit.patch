+void
+FqCobaltQueueDisc::ScanAndDropRedundant(uint32_t flowIndex,
+                                        uint32_t newAckNum,
+                                        const AckFilterFlowKey& newKey,
+                                        bool aggressive)
+{
+    NS_LOG_FUNCTION(this << flowIndex << newAckNum << aggressive);
+    Ptr<QueueDiscClass> qdClass = GetQueueDiscClass(flowIndex);
+    if (!qdClass)
+    {
+        return;
+    }
+    Ptr<QueueDisc> inner = qdClass->GetQueueDisc();
+    if (!inner)
+    {
+        return;
+    }
+    Ptr<QueueBase> internalBase = inner->GetInternalQueue(0);
+    Ptr<Queue<QueueDiscItem>> internal = DynamicCast<Queue<QueueDiscItem>>(internalBase);
+    if (!internal)
+    {
+        return;
+    }

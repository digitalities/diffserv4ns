+/**
+ * @ingroup system-tests-tc
+ *
+ * Verify the polymorphic host-hash virtuals on Ipv4QueueDiscItem produce
+ * the relationships required by the set-associative host-isolation design:
+ *   - distinct (src, dst) pairs map to distinct host hashes
+ *   - same source IP yields the same source-host hash regardless of destination
+ *   - same destination IP yields the same destination-host hash regardless of source
+ *   - varying the perturbation alters both host hashes
+ *
+ * The test exercises the virtuals directly on Ipv4QueueDiscItem; no static
+ * helper sits between the caller and the polymorphic dispatch.
+ */
+class FqCobaltQueueDiscHostIsoHashExtraction : public TestCase
+{
+  public:
+    FqCobaltQueueDiscHostIsoHashExtraction();
+    ~FqCobaltQueueDiscHostIsoHashExtraction() override;
+
+  private:
+    void DoRun() override;
+};
+
+FqCobaltQueueDiscHostIsoHashExtraction::FqCobaltQueueDiscHostIsoHashExtraction()
+    : TestCase("Test polymorphic HashSrcHost and HashDstHost on Ipv4QueueDiscItem")
+{
+}
+
+FqCobaltQueueDiscHostIsoHashExtraction::~FqCobaltQueueDiscHostIsoHashExtraction()
+{
+}
+
+void
+FqCobaltQueueDiscHostIsoHashExtraction::DoRun()
+{
+    const uint32_t p = 0x12345678;
+
+    Ipv4Address ip1("10.0.0.1");
+    Ipv4Address ip2("10.0.0.2");
+    Ipv4Address ip3("10.0.0.3");
+
+    Ptr<Ipv4QueueDiscItem> a = MakeIpv4HostHashItem(ip1, ip2);
+    Ptr<Ipv4QueueDiscItem> b = MakeIpv4HostHashItem(ip3, ip2); // same dst as a, different src
+    Ptr<Ipv4QueueDiscItem> c = MakeIpv4HostHashItem(ip1, ip3); // same src as a, different dst
+
+    uint32_t aSrc = a->HashSrcHost(p);
+    uint32_t aDst = a->HashDstHost(p);
+    uint32_t bSrc = b->HashSrcHost(p);
+    uint32_t bDst = b->HashDstHost(p);
+    uint32_t cSrc = c->HashSrcHost(p);
+    uint32_t cDst = c->HashDstHost(p);
+
+    // Sub-case 1: distinct (src, dst) pairs → distinct host hashes.
+    NS_TEST_ASSERT_MSG_NE(aSrc, bSrc, "Different sources must produce different srchost hashes");
+    NS_TEST_ASSERT_MSG_NE(aDst, cDst, "Different destinations must produce different dsthost hashes");
+
+    // Sub-case 2: same source, different destination → identical srchost, different dsthost.
+    NS_TEST_ASSERT_MSG_EQ(aSrc, cSrc, "Same source IP must produce the same srchost hash");
+    NS_TEST_ASSERT_MSG_NE(aDst, cDst, "Different destination IPs must produce different dsthost hashes");
+
+    // Sub-case 3: same destination, different source → different srchost, identical dsthost.
+    NS_TEST_ASSERT_MSG_NE(aSrc, bSrc, "Different source IPs must produce different srchost hashes");
+    NS_TEST_ASSERT_MSG_EQ(aDst, bDst, "Same destination IP must produce the same dsthost hash");
+
+    // Sub-case 4: varying the perturbation alters both host hashes.
+    const uint32_t pAlt = 0xdeadbeef;
+    uint32_t aSrcAlt = a->HashSrcHost(pAlt);
+    uint32_t aDstAlt = a->HashDstHost(pAlt);
+    NS_TEST_ASSERT_MSG_NE(aSrc, aSrcAlt, "Perturbation must alter the srchost hash");
+    NS_TEST_ASSERT_MSG_NE(aDst, aDstAlt, "Perturbation must alter the dsthost hash");
+
+    // Sub-case 5: srchost and dsthost are distinct hash spaces (asymmetric layout).
+    // For a generic (src != dst) pair, the buffer (src, 0, p) differs from (0, dst, p)
+    // and Murmur3 will not collide on these.
+    NS_TEST_ASSERT_MSG_NE(aSrc, aDst, "Srchost and dsthost hashes must be distinct for src != dst");
+
+    // Sub-case 6: base-class default returns 0 for items without an IPv4 override.
+    // Confirmed indirectly by Ipv4QueueDiscItem returning non-zero here; the base
+    // default-return-0 is verified by construction (the virtual exists on
+    // QueueDiscItem and returns 0 unless overridden).
+    NS_TEST_ASSERT_MSG_NE(aSrc, 0u, "Ipv4 override must produce a non-zero srchost hash");
+    NS_TEST_ASSERT_MSG_NE(aDst, 0u, "Ipv4 override must produce a non-zero dsthost hash");
+}

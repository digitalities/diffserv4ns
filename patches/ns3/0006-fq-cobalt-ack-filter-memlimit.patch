+/**
+ * @ingroup system-tests-tc
+ *
+ * Build an IPv4 + TCP ACK-only Ipv4QueueDiscItem with the given 5-tuple
+ * and cumulative ACK number. Used by the ACK-filter test below.
+ */
+static Ptr<Ipv4QueueDiscItem>
+MakeAckOnlyItem(Ipv4Address src,
+                Ipv4Address dst,
+                uint16_t srcPort,
+                uint16_t dstPort,
+                uint32_t ackNum)
+{
+    TcpHeader tcp;
+    tcp.SetSourcePort(srcPort);
+    tcp.SetDestinationPort(dstPort);
+    tcp.SetAckNumber(SequenceNumber32(ackNum));
+    tcp.SetSequenceNumber(SequenceNumber32(1));
+    tcp.SetFlags(TcpHeader::ACK);
+    tcp.SetWindowSize(65535);
+
+    Ptr<Packet> p = Create<Packet>();
+    p->AddHeader(tcp);
+
+    Ipv4Header ip;
+    ip.SetSource(src);
+    ip.SetDestination(dst);
+    ip.SetProtocol(6);
+    ip.SetPayloadSize(p->GetSize());
+    return Create<Ipv4QueueDiscItem>(p, Address(), 0x0800, ip);
+}
+
+/**
+ * @ingroup system-tests-tc
+ *
+ * Build an IPv4 + TCP ACK with a single SACK block appended (TCP option
+ * kind 5). The SACK block range defaults to [50, 60] for the legacy
+ * caller; later callers may pass an explicit range to drive SACK-range
+ * comparison logic.
+ */
+static Ptr<Ipv4QueueDiscItem>
+MakeAckOnlyItemWithSack(Ipv4Address src,
+                        Ipv4Address dst,
+                        uint16_t srcPort,
+                        uint16_t dstPort,
+                        uint32_t ackNum,
+                        uint32_t sackBegin = 50,
+                        uint32_t sackEnd = 60)
+{
+    TcpHeader tcp;
+    tcp.SetSourcePort(srcPort);
+    tcp.SetDestinationPort(dstPort);
+    tcp.SetAckNumber(SequenceNumber32(ackNum));
+    tcp.SetSequenceNumber(SequenceNumber32(1));
+    tcp.SetFlags(TcpHeader::ACK);
+    tcp.SetWindowSize(65535);
+
+    Ptr<TcpOptionSack> sack = CreateObject<TcpOptionSack>();
+    sack->AddSackBlock({SequenceNumber32(sackBegin), SequenceNumber32(sackEnd)});
+    tcp.AppendOption(sack);
+
+    Ptr<Packet> p = Create<Packet>();
+    p->AddHeader(tcp);
+
+    Ipv4Header ip;
+    ip.SetSource(src);
+    ip.SetDestination(dst);
+    ip.SetProtocol(6);
+    ip.SetPayloadSize(p->GetSize());
+    return Create<Ipv4QueueDiscItem>(p, Address(), 0x0800, ip);
+}
+
+/**
+ * @ingroup system-tests-tc
+ *
+ * Build an IPv4 + UDP Ipv4QueueDiscItem with the given 5-tuple. The UDP
+ * header's first four bytes (src / dst port) share the on-wire layout of
+ * a TCP header's first four bytes, so the inner Packet's bytes 0-3 are
+ * port-shaped; the IP protocol byte (17 for UDP, distinct from 6 for TCP)
+ * is what a self-defending ExtractFlowKey must check.
+ */
+static Ptr<Ipv4QueueDiscItem>
+MakeUdpItem(Ipv4Address src,
+            Ipv4Address dst,
+            uint16_t srcPort,
+            uint16_t dstPort,
+            uint32_t payloadSize = 64)
+{
+    UdpHeader udp;
+    udp.SetSourcePort(srcPort);
+    udp.SetDestinationPort(dstPort);
+
+    Ptr<Packet> p = Create<Packet>(payloadSize);
+    p->AddHeader(udp);
+
+    Ipv4Header ip;
+    ip.SetSource(src);
+    ip.SetDestination(dst);
+    ip.SetProtocol(17);
+    ip.SetPayloadSize(p->GetSize());
+    return Create<Ipv4QueueDiscItem>(p, Address(), 0x0800, ip);
+}

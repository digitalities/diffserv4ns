+/**
+ * Build the direction-aware flow key for an IP + TCP queue item.
+ * Returns true when the item carries enough bytes for a TCP header and
+ * the polymorphic host hashes are well-defined; false otherwise (the
+ * caller must skip non-TCP / malformed items).
+ *
+ * Source / destination host hashes come from the polymorphic
+ * @c HashSrcHost / @c HashDstHost virtuals on @c QueueDiscItem (declared
+ * in the network module, so no internet-module link dependency is
+ * required); ports are read from bytes 0-3 of the inner packet (the TCP
+ * source / destination port fields).
+ */
+bool
+FqCobaltQueueDisc::ExtractFlowKey(Ptr<const QueueDiscItem> item, AckFilterFlowKey& key)
+{
+    if (!item)
+    {
+        return false;
+    }
+    // Self-defending TCP-only gate. The inner Packet's bytes 0-3 are
+    // interpreted below as TCP src / dst port; for non-TCP items those
+    // bytes encode different things (UDP shares the layout but the L4
+    // semantics differ; ICMP has type / code / checksum). Polymorphic
+    // GetIpProtocol returns the IPv4 Protocol byte (or 0 if no L3
+    // context), so items without an IPv4 + TCP carrier are rejected
+    // here regardless of any upstream IsAckCandidate / IsValidAckTrigger
+    // gate.
+    if (item->GetIpProtocol() != 6)
+    {
+        return false;
+    }
+    Ptr<Packet> pkt = item->GetPacket();
+    if (!pkt || pkt->GetSize() < 4)
+    {
+        return false;
+    }
+    uint8_t buf[4];
+    pkt->CopyData(buf, 4);
+    key.srcPort = (uint16_t(buf[0]) << 8) | buf[1];
+    key.dstPort = (uint16_t(buf[2]) << 8) | buf[3];
+    // Zero perturbation gives a deterministic byte-equivalent comparator
+    // (two items with identical source-host bytes produce identical
+    // srcHash; the same holds for dstHash). The four-field tuple
+    // (srcHash, dstHash, srcPort, dstPort) cross-collides only when two
+    // distinct source/destination hosts both hash to the same 32-bit
+    // value AND both ports match, which is vanishingly unlikely in
+    // practice and exactly equivalent to the Linux direct-byte form for
+    // the ACK-filter's purposes.
+    key.srcHash = item->HashSrcHost(0);
+    key.dstHash = item->HashDstHost(0);
+    return true;
+}

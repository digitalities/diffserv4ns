+/**
+ * @ingroup system-tests-tc
+ *
+ * High-cardinality characterisation of the host-isolation set-associative
+ * hash. With m_flows=64 and 256 distinct source hosts each enqueueing one
+ * packet to a fixed destination, set-associative collisions are forced
+ * (256 distinct srchost hashes mapping into 8 sets x 8 ways = 64 slots).
+ * The patched implementation must share slots gracefully (tag overwrite,
+ * not LRU eviction nor admission rejection) and drain cleanly.
+ */
+class FqCobaltQueueDiscHostIsoHighCardinality : public TestCase
+{
+  public:
+    FqCobaltQueueDiscHostIsoHighCardinality();
+    ~FqCobaltQueueDiscHostIsoHighCardinality() override;
+
+  private:
+    void DoRun() override;
+};
+
+FqCobaltQueueDiscHostIsoHighCardinality::FqCobaltQueueDiscHostIsoHighCardinality()
+    : TestCase("Test high-cardinality host-isolation: 256 distinct source IPs into 64 slots")
+{
+}
+
+FqCobaltQueueDiscHostIsoHighCardinality::~FqCobaltQueueDiscHostIsoHighCardinality()
+{
+}
+
+void
+FqCobaltQueueDiscHostIsoHighCardinality::DoRun()
+{
+    Ptr<FqCobaltQueueDisc> q = CreateObjectWithAttributes<FqCobaltQueueDisc>(
+        "Flows",
+        UintegerValue(64),
+        "EnableHostIsolation",
+        BooleanValue(true),
+        "Perturbation",
+        UintegerValue(0));
+    q->SetQuantum(1514);
+    q->Initialize();
+    q->SetHostIsolationMode(FqCobaltQueueDisc::HostIsolationMode::Triple);
+
+    const Ipv4Address kDst("10.99.99.99");
+    const uint32_t kNumHosts = 256;
+    uint32_t enqueueAccepted = 0;
+
+    // Enqueue one packet from each of 256 distinct source IPs.
+    // Encoding: 10.<(h>>16)&0xff>.<(h>>8)&0xff>.<(h&0xff)|1> guarantees the
+    // last octet is non-zero (avoids broadcast-style 10.0.0.0).
+    for (uint32_t h = 0; h < kNumHosts; ++h)
+    {
+        uint8_t b1 = static_cast<uint8_t>((h >> 16) & 0xff);
+        uint8_t b2 = static_cast<uint8_t>((h >> 8) & 0xff);
+        uint8_t b3 = static_cast<uint8_t>((h & 0xff) | 0x1);
+        std::ostringstream oss;
+        oss << "10." << static_cast<uint32_t>(b1) << "." << static_cast<uint32_t>(b2) << "."
+            << static_cast<uint32_t>(b3);
+        Ipv4Address src(oss.str().c_str());
+        bool ok = q->Enqueue(MakeIpv4HostHashItem(src, kDst));
+        if (ok)
+        {
+            ++enqueueAccepted;
+        }
+    }
+
+    // Sanity: majority of enqueues accepted (graceful set-associative
+    // sharing, not pathological rejection like an LRU-evicting wrapper).
+    NS_TEST_ASSERT_MSG_GT(enqueueAccepted,
+                          128u,
+                          "Expected >128 of 256 enqueues to be accepted, got "
+                              << enqueueAccepted);
+
+    // Drain the queue completely; each Dequeue must return non-null until
+    // the queue is empty. No crash, no stuck packet.
+    uint32_t drained = 0;
+    while (true)
+    {
+        Ptr<QueueDiscItem> item = q->Dequeue();
+        if (!item)
+        {
+            break;
+        }
+        ++drained;
+    }
+
+    NS_TEST_ASSERT_MSG_EQ(drained,
+                          enqueueAccepted,
+                          "Drained count must equal accepted enqueues");
+
+    // Queue must be empty after drain.
+    Ptr<QueueDiscItem> tail = q->Dequeue();
+    NS_TEST_ASSERT_MSG_EQ(tail, nullptr, "Queue must be empty after full drain");
+
+    Simulator::Destroy();
+}

+    // m_traceDequeue on the inner queue; the outer disc's
+    // PacketDequeued callback (queue-disc.cc) decrements m_nPackets /
+    // m_nBytes / GetNBytes(), which is what the surrounding `while`
+    // loop is testing.
+    Ptr<QueueDiscItem> dropped = internal->Dequeue();
+    if (!dropped)
+    {
+        return false;
+    }
+
+    NS_LOG_DEBUG("Memlimit evict: drop " << dropped->GetSize() << "B from longest flow ("
+                                         << maxBytes << "B backlog); cap=" << m_memLimit << "B");
+    DropAfterDequeue(dropped, MEMLIMIT_DROP);

+/**
+ * @ingroup system-tests-tc
+ *
+ * Verify the integrated host-isolation behaviour through the full DoEnqueue /
+ * DoDequeue dispatch path. Two flows share the same source IP but have
+ * different destinations, so they should map to the same srchost slot and
+ * different dsthost slots under Triple mode. After enqueueing four packets
+ * for each flow, srchost_bulk_flow_count at the shared slot should reach 2.
+ * After fully draining both flows, the counter returns to 0.
+ */
+class FqCobaltQueueDiscHostIsoCounterIntegration : public TestCase
+{
+  public:
+    FqCobaltQueueDiscHostIsoCounterIntegration();
+    ~FqCobaltQueueDiscHostIsoCounterIntegration() override;
+
+  private:
+    void DoRun() override;
+};
+
+FqCobaltQueueDiscHostIsoCounterIntegration::FqCobaltQueueDiscHostIsoCounterIntegration()
+    : TestCase("Test bulk-flow counters update through DoEnqueue plus DoDequeue cycle")
+{
+}
+
+FqCobaltQueueDiscHostIsoCounterIntegration::~FqCobaltQueueDiscHostIsoCounterIntegration()
+{
+}
+
+void
+FqCobaltQueueDiscHostIsoCounterIntegration::DoRun()
+{
+    Ptr<FqCobaltQueueDisc> q = CreateObjectWithAttributes<FqCobaltQueueDisc>(
+        "Flows",
+        UintegerValue(64),
+        "EnableHostIsolation",
+        BooleanValue(true),
+        "Perturbation",
+        UintegerValue(0));
+    q->SetQuantum(1514);
+    q->Initialize();
+
+    const Ipv4Address kSrc("10.1.1.1");
+    const Ipv4Address kDstA("10.2.2.1");
+    const Ipv4Address kDstB("10.2.2.2");
+
+    // Resolve the expected srchost slot up front. The polymorphic virtual
+    // gives the host-hash; the disc's ResolveHostSlot maps that to a slot
+    // index. Both flows below share kSrc so they map to the same slot.
+    Ptr<Ipv4QueueDiscItem> probe = MakeIpv4HostHashItem(kSrc, kDstA);
+    const uint32_t srchostHash = probe->HashSrcHost(0u);
+    const uint32_t srchostSlot = q->ResolveHostSlot(srchostHash);
+
+    // Enqueue 4 packets each for flow A (src→dstA) and flow B (src→dstB).
+    // The flow-hash differs between A and B (destination IP differs) so
+    // FqCobalt creates two distinct flow queues; both share kSrc so they
+    // count against the same srchost slot.
+    for (uint32_t i = 0; i < 4u; ++i)
+    {
+        q->Enqueue(MakeIpv4HostHashItem(kSrc, kDstA));
+    }
+    for (uint32_t i = 0; i < 4u; ++i)
+    {
+        q->Enqueue(MakeIpv4HostHashItem(kSrc, kDstB));
+    }
+
+    // After enqueueing both flows, srchost_bulk_flow_count at the shared
+    // src-host slot reaches 2 (one per flow that transitioned INACTIVE→active).
+    NS_TEST_ASSERT_MSG_EQ(q->GetSrchostBulkFlowCountAt(srchostSlot),
+                          2u,
+                          "Both bulk flows must count against the shared src host");
+
+    // Drain the queue completely; FqCobalt's round-robin dispatches the eight
+    // packets across the two flows. After each flow is empty it transitions
+    // INACTIVE and Dec's the per-host counter.
+    for (uint32_t i = 0; i < 8u; ++i)
+    {
+        Ptr<QueueDiscItem> item = q->Dequeue();
+        NS_TEST_ASSERT_MSG_NE(item, nullptr, "Dequeue must return an item while queue is non-empty");
+    }
+    NS_TEST_ASSERT_MSG_EQ(q->Dequeue(),
+                          nullptr,
+                          "Queue must be empty after draining all 8 enqueued packets");
+
+    // Both flows have drained; both DecSrchostBulkFlowCount calls should have
+    // fired, bringing the shared srchost counter back to 0.
+    NS_TEST_ASSERT_MSG_EQ(q->GetSrchostBulkFlowCountAt(srchostSlot),
+                          0u,
+                          "All flows drained: srchost counter must return to 0");
+    Simulator::Destroy();
+}

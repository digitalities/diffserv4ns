+FqCobaltQueueDiscHostIsoMemLimitComposition::FqCobaltQueueDiscHostIsoMemLimitComposition()
+    : TestCase("Test EnableHostIsolation composes with MemLimit post-everything eviction")
+{
+}
+
+FqCobaltQueueDiscHostIsoMemLimitComposition::~FqCobaltQueueDiscHostIsoMemLimitComposition()
+{
+}
+
+void
+FqCobaltQueueDiscHostIsoMemLimitComposition::DoRun()
+{
+    constexpr uint32_t kCapBytes = 500;
+    constexpr uint32_t kArrivals = 20;
+
+    Ptr<FqCobaltQueueDisc> q = CreateObjectWithAttributes<FqCobaltQueueDisc>(
+        "MemLimit",
+        UintegerValue(kCapBytes),
+        "EnableHostIsolation",
+        BooleanValue(true));
+    q->SetQuantum(1514);
+    q->Initialize();
+    q->SetHostIsolationMode(FqCobaltQueueDisc::HostIsolationMode::Triple);
+
+    const Ipv4Address src("10.1.1.1");
+    const Ipv4Address dst("10.2.2.2");
+
+    uint32_t admitted = 0;
+    for (uint32_t i = 0; i < kArrivals; ++i)
+    {
+        if (q->Enqueue(MakeIpv4HostHashItem(src, dst)))
+        {
+            ++admitted;
+        }
+    }
+
+    NS_TEST_ASSERT_MSG_EQ(admitted,
+                          kArrivals,
+                          "Linux-faithful MemLimit has no pre-enqueue gate; all arrivals "
+                          "must be admitted when host-isolation is engaged.");
+    NS_TEST_ASSERT_MSG_LT_OR_EQ(
+        q->GetNBytes(),
+        kCapBytes,
+        "Post-everything eviction must bound queued bytes at the cap even when "
+        "host-isolation is engaged.");
+    const QueueDisc::Stats stats = q->GetStats();
+    const auto& reasonMap = stats.nDroppedPacketsAfterDequeue;
+    const std::size_t keyPresent = reasonMap.count(FqCobaltQueueDisc::MEMLIMIT_DROP);
+    const uint32_t evictions =
+        (keyPresent == 1u) ? reasonMap.at(FqCobaltQueueDisc::MEMLIMIT_DROP) : 0u;
+    NS_TEST_ASSERT_MSG_GT(evictions,
+                          0u,
+                          "Per-reason MEMLIMIT_DROP credit must be > 0 when over-cap "
+                          "arrivals drive eviction under host-isolation.");
+
+    Simulator::Destroy();
+}
+
+/**
+ * @ingroup system-tests-tc
+ *
+ * Verify the polymorphic host-hash virtuals on Ipv6QueueDiscItem are
+ * overridden (i.e. they do NOT collapse to the default-return-0 path) and
+ * produce the same relationships as the IPv4 overrides:
+ *   - distinct sources → distinct srchost hashes
+ *   - same source, different destinations → same srchost, different dsthost
+ *   - perturbation alters both
+ *   - hash is non-zero (the empty-slot sentinel is reserved)
+ *
+ * Without this override, every IPv6 flow's host-hash would be zero and every
+ * IPv6 source would collide onto slot 0 of the host-isolation table.
+ */
+class FqCobaltQueueDiscHostIsoIpv6Hash : public TestCase
+{
+  public:
+    FqCobaltQueueDiscHostIsoIpv6Hash();
+    ~FqCobaltQueueDiscHostIsoIpv6Hash() override;
+
+  private:
+    void DoRun() override;
+};
+
+FqCobaltQueueDiscHostIsoIpv6Hash::FqCobaltQueueDiscHostIsoIpv6Hash()
+    : TestCase("Test polymorphic HashSrcHost and HashDstHost on Ipv6QueueDiscItem")
+{
+}
+
+FqCobaltQueueDiscHostIsoIpv6Hash::~FqCobaltQueueDiscHostIsoIpv6Hash()
+{
+}
+
+void
+FqCobaltQueueDiscHostIsoIpv6Hash::DoRun()
+{
+    const uint32_t p = 0x12345678;
+
+    Ipv6Address ip1("2001:db8::1");
+    Ipv6Address ip2("2001:db8::2");
+    Ipv6Address ip3("2001:db8::3");
+
+    Ptr<Ipv6QueueDiscItem> a = MakeIpv6HostHashItem(ip1, ip2);
+    Ptr<Ipv6QueueDiscItem> b = MakeIpv6HostHashItem(ip3, ip2); // same dst, different src
+    Ptr<Ipv6QueueDiscItem> c = MakeIpv6HostHashItem(ip1, ip3); // same src, different dst
+
+    uint32_t aSrc = a->HashSrcHost(p);
+    uint32_t aDst = a->HashDstHost(p);
+    uint32_t bSrc = b->HashSrcHost(p);
+    uint32_t bDst = b->HashDstHost(p);
+    uint32_t cSrc = c->HashSrcHost(p);
+    uint32_t cDst = c->HashDstHost(p);
+
+    // Sub-case 1: same source IP yields the same source-host hash (across
+    // different destinations).
+    NS_TEST_ASSERT_MSG_EQ(aSrc, cSrc, "Same source IPv6 must produce the same srchost hash");
+    // Sub-case 2: different source IPs yield different source-host hashes.
+    NS_TEST_ASSERT_MSG_NE(aSrc, bSrc, "Different source IPv6s must produce different srchost hashes");
+    // Sub-case 3: same destination IP yields the same destination-host hash
+    // (across different sources).
+    NS_TEST_ASSERT_MSG_EQ(aDst, bDst, "Same destination IPv6 must produce the same dsthost hash");
+    // Sub-case 4: different destination IPs yield different dsthost hashes.
+    NS_TEST_ASSERT_MSG_NE(aDst, cDst, "Different destination IPv6s must produce different dsthost hashes");
+    // Sub-case 5: perturbation alters both host hashes.
+    const uint32_t pAlt = 0xdeadbeef;
+    NS_TEST_ASSERT_MSG_NE(aSrc, a->HashSrcHost(pAlt), "Perturbation must alter the srchost hash");
+    NS_TEST_ASSERT_MSG_NE(aDst, a->HashDstHost(pAlt), "Perturbation must alter the dsthost hash");
+    // Sub-case 6: hashes are non-zero (0 is the empty-slot sentinel).
+    NS_TEST_ASSERT_MSG_NE(aSrc, 0u, "Ipv6 srchost hash must be non-zero");
+    NS_TEST_ASSERT_MSG_NE(aDst, 0u, "Ipv6 dsthost hash must be non-zero");
+    // Sub-case 7: a default-constructed (non-IPv4, non-IPv6) item path is
+    // verified at the QueueDiscItem level — the IPv6 override here proves
+    // the polymorphic dispatch reaches the IPv6 subclass.
+    NS_TEST_ASSERT_MSG_NE(aSrc, aDst, "Srchost and dsthost hashes must be distinct for src != dst");
+}
+
+/**
+ * @ingroup system-tests-tc
+ *
+ * Regression test for the outer QueueDisc nTotalReceivedPackets ==
+ * nTotalDroppedPacketsBeforeEnqueue + nTotalEnqueuedPackets invariant
+ * under bidirectional saturating TCP-equivalent ACK bursts.
+ *
+ * The v1.0 ACK filter implementation triggered an assertion at
+ * queue-disc.cc:896 because its drain-and-refill ScanAndDropRedundant
+ * fired inner->outer PacketEnqueued traces for every survivor re-enqueue,
+ * inflating outer's nTotalEnqueuedPackets without matching nTotalReceived
+ * increments. This test captures the same workload pattern and asserts
+ * the invariant holds in v1.1's in-place implementation.
+ */
+/**
+ * @ingroup system-tests-tc
+ *
+ * Six per-divergence sub-tests verifying that the v1.1 ACK filter
+ * matches Linux cake_ack_filter() semantics row-by-row.
+ */
+class AckFilterDivergenceTest : public TestCase
+{
+  public:
+    AckFilterDivergenceTest()
+        : TestCase("FqCobalt ACK filter: Linux cake_ack_filter() semantic "
+                   "alignment (6 sub-cases per the v1.0 source audit)")
+    {
+    }
+
+  private:
+    void DoRun() override;
+
+    void TestExactFiveTupleMatch();
+    void TestPshUrgFinRstExclusion();
+    void TestTimestampAndSegmentData();
+    void TestSackComparison();
+    void TestEligibilityStateMachine();
+    void TestAggressiveConsecutiveShortcut();
+
+    /// Helper: build an FqCobaltQueueDisc with ACK filter enabled +
+    /// optional aggressive flag.
+    Ptr<FqCobaltQueueDisc> MakeDisc(bool aggressive = false);
+
+    /// Helper: enqueue an item, return the disc's stats snapshot.
+    QueueDisc::Stats EnqueueAndSnapshot(Ptr<FqCobaltQueueDisc> q,
+                                        Ptr<QueueDiscItem> item);
+};
+
+Ptr<FqCobaltQueueDisc>
+AckFilterDivergenceTest::MakeDisc(bool aggressive)
+{
+    Ptr<FqCobaltQueueDisc> q = CreateObject<FqCobaltQueueDisc>();
+    q->SetQuantum(1500);
+    q->SetAttribute("EnableAckFilter", BooleanValue(true));
+    q->SetAttribute("EnableAckFilterAggressive", BooleanValue(aggressive));
+    q->Initialize();
+    return q;
+}
+
+QueueDisc::Stats
+AckFilterDivergenceTest::EnqueueAndSnapshot(Ptr<FqCobaltQueueDisc> q,
+                                            Ptr<QueueDiscItem> item)
+{
+    q->Enqueue(item);
+    return q->GetStats();
+}
+
+void
+AckFilterDivergenceTest::DoRun()
+{
+    TestExactFiveTupleMatch();
+    TestPshUrgFinRstExclusion();
+    TestTimestampAndSegmentData();
+    TestSackComparison();
+    TestEligibilityStateMachine();
+    TestAggressiveConsecutiveShortcut();
+}
+
+void
+AckFilterDivergenceTest::TestExactFiveTupleMatch()
+{
+    Ptr<FqCobaltQueueDisc> q = MakeDisc();
+
+    // Two distinct 5-tuples that may or may not hash to the same flow
+    // bucket. The new arrival (b) and the queued item (a) are
+    // byte-swapped IP+port pairs (10.0.0.1:1000->10.0.0.2:2000 vs
+    // 10.0.0.2:2000->10.0.0.1:1000). They differ in 5-tuple but might
+    // share a hash bucket depending on perturbation. Under exact
+    // 5-tuple matching (Linux cake_ack_filter at sch_cake.c:1268-1276)
+    // a must NOT be dropped regardless of whether they hash-collide.
+    //
+    // If the chosen tuples happen NOT to collide in this implementation
+    // the test passes vacuously — the structural change still removes
+    // the hash-collision false-positive risk. Recorded in commit body.
+
+    Ptr<Ipv4QueueDiscItem> a = MakeAckOnlyItem(Ipv4Address("10.0.0.1"),
+                                               Ipv4Address("10.0.0.2"),
+                                               1000, 2000, 5000);
+    Ptr<Ipv4QueueDiscItem> bNewer = MakeAckOnlyItem(Ipv4Address("10.0.0.2"),
+                                                    Ipv4Address("10.0.0.1"),
+                                                    2000, 1000, 6000);
+
+    q->Enqueue(a);
+    QueueDisc::Stats before = q->GetStats();
+    q->Enqueue(bNewer);
+    QueueDisc::Stats after = q->GetStats();
+
+    // The reverse-direction ACK (b) must NOT cause the forward-direction
+    // ACK (a) to be dropped, regardless of whether they hash-collide.
+    // Mirrors Linux sch_cake.c:1268-1276 (direct field comparison).
+    NS_TEST_ASSERT_MSG_EQ(after.nTotalDroppedPacketsAfterDequeue,
+                          before.nTotalDroppedPacketsAfterDequeue,
+                          "Distinct 5-tuples must not cross-trigger ACK "
+                          "filter drops (mirrors sch_cake.c:1268-1276)");
+}
+
+void
+AckFilterDivergenceTest::TestPshUrgFinRstExclusion()
+{
+    Ptr<FqCobaltQueueDisc> q = MakeDisc();
+
+    // Enqueue an ACK with PSH flag set (data-bearing ACK from the
+    // application layer; Linux preserves these). Then enqueue a plain
+    // newer ACK on the same 5-tuple. The PSH ACK must survive.
+
+    auto makePshAck = [](uint32_t ackNum) {
+        TcpHeader tcp;
+        tcp.SetSourcePort(12345);
+        tcp.SetDestinationPort(80);
+        tcp.SetAckNumber(SequenceNumber32(ackNum));
+        tcp.SetSequenceNumber(SequenceNumber32(1));
+        tcp.SetFlags(TcpHeader::ACK | TcpHeader::PSH);
+        tcp.SetWindowSize(65535);
+        Ptr<Packet> p = Create<Packet>();
+        p->AddHeader(tcp);
+        Ipv4Header ip;
+        ip.SetSource(Ipv4Address("10.0.0.1"));
+        ip.SetDestination(Ipv4Address("10.0.0.2"));
+        ip.SetProtocol(6);
+        ip.SetPayloadSize(p->GetSize());
+        return Create<Ipv4QueueDiscItem>(p, Address(), 0x0800, ip);
+    };
+
+    q->Enqueue(makePshAck(5000));
+    QueueDisc::Stats before = q->GetStats();
+
+    // Plain ACK with newer ack number on same 5-tuple
+    q->Enqueue(MakeAckOnlyItem(Ipv4Address("10.0.0.1"),
+                               Ipv4Address("10.0.0.2"),
+                               12345, 80, 6000));
+    QueueDisc::Stats after = q->GetStats();
+
+    NS_TEST_ASSERT_MSG_EQ(after.nTotalDroppedPacketsAfterDequeue,
+                          before.nTotalDroppedPacketsAfterDequeue,
+                          "PSH-bearing ACK must survive ACK filter "
+                          "(mirrors sch_cake.c:1306-1316 cake_tcph_may_drop)");
+
+    // Same test with URG, FIN, RST in turn.
+    for (auto flag : { (uint8_t)TcpHeader::URG, (uint8_t)TcpHeader::FIN,
+                       (uint8_t)TcpHeader::RST })
+    {
+        Ptr<FqCobaltQueueDisc> q2 = MakeDisc();
+        TcpHeader t;
+        t.SetSourcePort(12345);
+        t.SetDestinationPort(80);
+        t.SetAckNumber(SequenceNumber32(5000));
+        t.SetSequenceNumber(SequenceNumber32(1));
+        t.SetFlags(TcpHeader::ACK | flag);
+        t.SetWindowSize(65535);
+        Ptr<Packet> p = Create<Packet>();
+        p->AddHeader(t);
+        Ipv4Header ip;
+        ip.SetSource(Ipv4Address("10.0.0.1"));
+        ip.SetDestination(Ipv4Address("10.0.0.2"));
+        ip.SetProtocol(6);
+        ip.SetPayloadSize(p->GetSize());
+        q2->Enqueue(Create<Ipv4QueueDiscItem>(p, Address(), 0x0800, ip));
+        QueueDisc::Stats b2 = q2->GetStats();
+        q2->Enqueue(MakeAckOnlyItem(Ipv4Address("10.0.0.1"),
+                                    Ipv4Address("10.0.0.2"),
+                                    12345, 80, 6000));
+        QueueDisc::Stats a2 = q2->GetStats();
+        NS_TEST_ASSERT_MSG_EQ(a2.nTotalDroppedPacketsAfterDequeue,
+                              b2.nTotalDroppedPacketsAfterDequeue,
+                              "Flag-bearing ACK must survive ACK filter");
+    }
+}
+
+void
+AckFilterDivergenceTest::TestTimestampAndSegmentData()
+{
+    // Sub-case A: ACK with data payload (segment-len > 0) must survive.
+    // Mirrors Linux cake_tcph_may_drop at sch_cake.c:1313 (the "skb->len !=
+    // tcp_hdr_len" guard). Already enforced by v1.0 IsAckCandidate via the
+    // payload==0 terminal check; this sub-case is a regression guard.
+    {
+        Ptr<FqCobaltQueueDisc> q = MakeDisc();
+        TcpHeader t;
+        t.SetSourcePort(12345);
+        t.SetDestinationPort(80);
+        t.SetAckNumber(SequenceNumber32(5000));
+        t.SetSequenceNumber(SequenceNumber32(1));
+        t.SetFlags(TcpHeader::ACK);
+        t.SetWindowSize(65535);
+        Ptr<Packet> p = Create<Packet>(512); // 512 bytes payload
+        p->AddHeader(t);
+        Ipv4Header ip;
+        ip.SetSource(Ipv4Address("10.0.0.1"));
+        ip.SetDestination(Ipv4Address("10.0.0.2"));
+        ip.SetProtocol(6);
+        ip.SetPayloadSize(p->GetSize());
+        q->Enqueue(Create<Ipv4QueueDiscItem>(p, Address(), 0x0800, ip));
+
+        QueueDisc::Stats before = q->GetStats();
+        q->Enqueue(MakeAckOnlyItem(Ipv4Address("10.0.0.1"),
+                                   Ipv4Address("10.0.0.2"),
+                                   12345, 80, 6000));
+        QueueDisc::Stats after = q->GetStats();
+        NS_TEST_ASSERT_MSG_EQ(after.nTotalDroppedPacketsAfterDequeue,
+                              before.nTotalDroppedPacketsAfterDequeue,
+                              "ACK-with-data must survive ACK filter "
+                              "(mirrors sch_cake.c:1313)");
+    }
+
+    // Helper: build a queued ACK that carries a TCP timestamp option
+    // with the given (tsval, tsecr). Used by sub-cases B and C below.
+    auto makeAckWithTs = [](uint32_t ackNum, uint32_t tsval, uint32_t tsecr) {
+        TcpHeader t;
+        t.SetSourcePort(12345);
+        t.SetDestinationPort(80);
+        t.SetAckNumber(SequenceNumber32(ackNum));
+        t.SetSequenceNumber(SequenceNumber32(1));
+        t.SetFlags(TcpHeader::ACK);
+        t.SetWindowSize(65535);
+        Ptr<TcpOptionTS> ts = CreateObject<TcpOptionTS>();
+        ts->SetTimestamp(tsval);
+        ts->SetEcho(tsecr);
+        t.AppendOption(ts);
+        Ptr<Packet> p = Create<Packet>();
+        p->AddHeader(t);
+        Ipv4Header ip;
+        ip.SetSource(Ipv4Address("10.0.0.1"));
+        ip.SetDestination(Ipv4Address("10.0.0.2"));
+        ip.SetProtocol(6);
+        ip.SetPayloadSize(p->GetSize());
+        return Create<Ipv4QueueDiscItem>(p, Address(), 0x0800, ip);
+    };
+
+    // Sub-case B: TS-bearing ACK is PRESERVED when the queued TS pair is
+    // STRICTLY NEWER than the trigger's (carries TS information the
+    // trigger has not yet superseded). Mirrors Linux cake_tcph_may_drop
+    // TIMESTAMP branch at sch_cake.c:1196-1198: the queued is droppable
+    // iff !after(qTstamp, triggerTstamp) AND !after(qTsecr, triggerTsecr);
+    // when either half of the queued TS pair is strictly after the
+    // trigger's, the queued MUST survive. Two queued ACKs are enqueued
+    // to clear the conservative-mode 2-eligible threshold from
+    // sch_cake.c:1336-1356, so that the surviving-because-TS-is-newer
+    // predicate is exercised in isolation rather than being masked by
+    // the single-eligible threshold.
+    {
+        Ptr<FqCobaltQueueDisc> q = MakeDisc();
+        // Queued ACKs have STRICTLY NEWER TS pairs than the upcoming
+        // trigger -- both tsval (1500 / 1600) and tsecr (2500 / 2600)
+        // are after the trigger's (1200 / 2200), so the queued carry TS
+        // information the trigger does not.
+        q->Enqueue(makeAckWithTs(/*ackNum=*/5000, /*tsval=*/1500, /*tsecr=*/2500));
+        q->Enqueue(makeAckWithTs(/*ackNum=*/5500, /*tsval=*/1600, /*tsecr=*/2600));
+        QueueDisc::Stats before = q->GetStats();
+        // Trigger carries an OLDER TS pair than both queued ACKs -- the
+        // wrap-aware `!after()` gate forbids the drop, so both queued
+        // must survive even though two eligibles are present.
+        q->Enqueue(makeAckWithTs(/*ackNum=*/6000, /*tsval=*/1200, /*tsecr=*/2200));
+        QueueDisc::Stats after = q->GetStats();
+        NS_TEST_ASSERT_MSG_EQ(after.nTotalDroppedPacketsAfterDequeue,
+                              before.nTotalDroppedPacketsAfterDequeue,
+                              "TS-bearing ACK whose TS pair is strictly "
+                              "newer than the trigger's must survive the "
+                              "ACK filter (mirrors sch_cake.c:1196-1198)");
+    }
+
+    // Sub-case C: TS-bearing ACK is DROPPABLE when its TS value equals
+    // the trigger's (no information loss on drop). Two queued ACKs
+    // share the trigger's tsval to clear the 2-eligible threshold; the
+    // first-saved (closest to head, ackNum=5000) is the victim per
+    // Linux semantics at sch_cake.c:1338-1346.
+    {
+        Ptr<FqCobaltQueueDisc> q = MakeDisc();
+        q->Enqueue(makeAckWithTs(/*ackNum=*/5000, /*tsval=*/1500, /*tsecr=*/2500));
+        q->Enqueue(makeAckWithTs(/*ackNum=*/5500, /*tsval=*/1500, /*tsecr=*/2500));
+        QueueDisc::Stats before = q->GetStats();
+        // Trigger carries the SAME tsval as both queued ACKs -- queued
+        // ACKs carry no information the trigger does not, so the
+        // first-saved is droppable under the 2-eligible threshold.
+        q->Enqueue(makeAckWithTs(/*ackNum=*/6000, /*tsval=*/1500, /*tsecr=*/2500));
+        QueueDisc::Stats after = q->GetStats();
+        NS_TEST_ASSERT_MSG_EQ(after.nTotalDroppedPacketsAfterDequeue,
+                              before.nTotalDroppedPacketsAfterDequeue + 1,
+                              "TS-bearing ACK with TS pair equal to the "
+                              "trigger's must be droppable in conservative "
+                              "mode (mirrors sch_cake.c:1196-1198 + "
+                              "sch_cake.c:1336-1356)");
+    }
+
+    // Sub-case D: TS-presence asymmetry must preserve the queued ACK.
+    // A queued ACK with no TS option and a trigger that carries TS (or
+    // vice versa) implies one side carries information the other does
+    // not, so the queued must survive. Two queued plain ACKs are
+    // enqueued to clear the 2-eligible threshold; the TS-bearing
+    // trigger must NOT drop either of them because of the TS-presence
+    // mismatch.
+    {
+        Ptr<FqCobaltQueueDisc> q = MakeDisc();
+        q->Enqueue(MakeAckOnlyItem(Ipv4Address("10.0.0.1"),
+                                   Ipv4Address("10.0.0.2"),
+                                   12345, 80, 5000));
+        q->Enqueue(MakeAckOnlyItem(Ipv4Address("10.0.0.1"),
+                                   Ipv4Address("10.0.0.2"),
+                                   12345, 80, 5500));
+        QueueDisc::Stats before = q->GetStats();
+        // Trigger carries TS; queued ACKs do not -- mismatch must
+        // preserve both queued ACKs.
+        q->Enqueue(makeAckWithTs(/*ackNum=*/6000, /*tsval=*/1500, /*tsecr=*/2500));
+        QueueDisc::Stats after = q->GetStats();
+        NS_TEST_ASSERT_MSG_EQ(after.nTotalDroppedPacketsAfterDequeue,
+                              before.nTotalDroppedPacketsAfterDequeue,
+                              "TS-presence mismatch between trigger and "
+                              "queued must preserve the queued ACK "
+                              "(mirrors sch_cake.c:1196-1198)");
+    }
+
+    // Sub-case E: TS-bearing ACK is DROPPABLE when the queued TS pair is
+    // STRICTLY OLDER than the trigger's. Mirrors Linux cake_tcph_may_drop
+    // TIMESTAMP branch at sch_cake.c:1196-1198: the wrap-aware
+    // `!after()` gate admits the drop when both tsval and tsecr of the
+    // queued are at-or-before the trigger's. This is the dominant CUBIC
+    // case (back-to-back ACKs share monotonically-advancing TS pairs)
+    // and the empirical reason the ACK filter compresses streams; the
+    // earlier strict-equality gate silently suppressed all such drops.
+    // Two queued ACKs share OLDER TS pairs than the trigger to clear
+    // the 2-eligible threshold; the first-saved (closest to head,
+    // ackNum=5000) is the victim per Linux semantics at
+    // sch_cake.c:1338-1346.
+    {
+        Ptr<FqCobaltQueueDisc> q = MakeDisc();
+        q->Enqueue(makeAckWithTs(/*ackNum=*/5000, /*tsval=*/1000, /*tsecr=*/2000));
+        q->Enqueue(makeAckWithTs(/*ackNum=*/5500, /*tsval=*/1100, /*tsecr=*/2100));
+        QueueDisc::Stats before = q->GetStats();
+        // Trigger carries STRICTLY NEWER TS pair (1200 / 2200 > 1100 /
+        // 2100 > 1000 / 2000) -- both queued ACKs are TS-superseded, so
+        // the first-saved is droppable under the 2-eligible threshold.
+        q->Enqueue(makeAckWithTs(/*ackNum=*/6000, /*tsval=*/1200, /*tsecr=*/2200));
+        QueueDisc::Stats after = q->GetStats();
+        NS_TEST_ASSERT_MSG_EQ(after.nTotalDroppedPacketsAfterDequeue,
+                              before.nTotalDroppedPacketsAfterDequeue + 1,
+                              "TS-bearing ACK with TS pair strictly older "
+                              "than the trigger's must be droppable in "
+                              "conservative mode (mirrors sch_cake.c:1196-1198 "
+                              "+ sch_cake.c:1336-1356)");
+    }
+}
+
+void
+AckFilterDivergenceTest::TestSackComparison()
+{
+    // The v1.0 IsAckCandidate rejects all SACK-bearing ACKs in
+    // conservative mode (any SACK -> not a candidate). Linux compares
+    // SACK ranges and allows dropping the queued ACK whenever the
+    // triggering ACK reports a SACK range that already covers what the
+    // queued ACK reports. This sub-test verifies that a queued SACK-
+    // bearing ACK whose SACK block [1000, 2000] is a strict subset of
+    // the triggering ACK's SACK block [1000, 3000] is droppable in
+    // conservative mode (mirrors sch_cake.c:1318-1330).
+    //
+    // Two queued SACK-subset ACKs are enqueued so the trigger's walk
+    // finds two eligibles -- conservative mode requires the 2-eligible
+    // threshold to fire a drop (sch_cake.c:1336-1356). The first-saved
+    // (closest to head, ackNum=5000) is the victim.
+
+    Ptr<FqCobaltQueueDisc> q = MakeDisc();
+    q->Enqueue(MakeAckOnlyItemWithSack(Ipv4Address("10.0.0.1"),
+                                       Ipv4Address("10.0.0.2"),
+                                       12345, 80, 5000,
+                                       1000, 2000));
+    q->Enqueue(MakeAckOnlyItemWithSack(Ipv4Address("10.0.0.1"),
+                                       Ipv4Address("10.0.0.2"),
+                                       12345, 80, 5500,
+                                       1000, 1800));
+    QueueDisc::Stats before = q->GetStats();
+    q->Enqueue(MakeAckOnlyItemWithSack(Ipv4Address("10.0.0.1"),
+                                       Ipv4Address("10.0.0.2"),
+                                       12345, 80, 6000,
+                                       1000, 3000));
+    QueueDisc::Stats after = q->GetStats();
+    NS_TEST_ASSERT_MSG_EQ(after.nTotalDroppedPacketsAfterDequeue,
+                          before.nTotalDroppedPacketsAfterDequeue + 1,
+                          "SACK-superset trigger should drop first-saved "
+                          "SACK-subset queued ACK in conservative mode "
+                          "(mirrors sch_cake.c:1318-1330; 2-eligible "
+                          "threshold per sch_cake.c:1336-1356)");
+
+    // Sub-case E: equal-cumulative-ACK + trigger-SACK-superset.
+    // Linux cake_tcph_sack_compare at sch_cake.c:1324-1326 treats
+    // equal-cumulative-ACK as droppable PROVIDED the trigger SACKs
+    // strictly more than the queued -- a same-ACK retransmission of
+    // a SACK report that the trigger has already extended carries no
+    // information past what the trigger already conveys, so dropping
+    // it does not lose any selective-acknowledgement state.
+    //
+    // The v1.0 `(qAckNum != newAckNum)` guard erroneously preserved
+    // this case; v1.1 lifts the guard and lets the SACK comparator
+    // decide.
+    Ptr<FqCobaltQueueDisc> qE = MakeDisc();
+    qE->Enqueue(MakeAckOnlyItemWithSack(Ipv4Address("10.0.0.1"),
+                                        Ipv4Address("10.0.0.2"),
+                                        12345, 80, 7000,
+                                        1000, 2000));
+    qE->Enqueue(MakeAckOnlyItemWithSack(Ipv4Address("10.0.0.1"),
+                                        Ipv4Address("10.0.0.2"),
+                                        12345, 80, 7000,
+                                        1000, 1800));
+    QueueDisc::Stats beforeE = qE->GetStats();
+    qE->Enqueue(MakeAckOnlyItemWithSack(Ipv4Address("10.0.0.1"),
+                                        Ipv4Address("10.0.0.2"),
+                                        12345, 80, 7000,
+                                        1000, 3000));
+    QueueDisc::Stats afterE = qE->GetStats();
+    NS_TEST_ASSERT_MSG_EQ(afterE.nTotalDroppedPacketsAfterDequeue,
+                          beforeE.nTotalDroppedPacketsAfterDequeue + 1,
+                          "Equal-cumulative-ACK + trigger-SACK-superset "
+                          "should drop first-saved queued ACK in "
+                          "conservative mode (mirrors sch_cake.c:1324-1326)");
+
+    // Sub-case F: equal-cumulative-ACK + equal SACK = pure duplicate.
+    // Linux preserves duplicates when the trigger conveys no new
+    // information past the queued (same cumulative ACK + equivalent
+    // SACK report). Dropping a pure duplicate would erode the ACK
+    // clock without informational gain.
+    Ptr<FqCobaltQueueDisc> qF = MakeDisc();
+    qF->Enqueue(MakeAckOnlyItemWithSack(Ipv4Address("10.0.0.1"),
+                                        Ipv4Address("10.0.0.2"),
+                                        12345, 80, 8000,
+                                        1000, 2000));
+    qF->Enqueue(MakeAckOnlyItemWithSack(Ipv4Address("10.0.0.1"),
+                                        Ipv4Address("10.0.0.2"),
+                                        12345, 80, 8000,
+                                        1000, 2000));
+    QueueDisc::Stats beforeF = qF->GetStats();
+    qF->Enqueue(MakeAckOnlyItemWithSack(Ipv4Address("10.0.0.1"),
+                                        Ipv4Address("10.0.0.2"),
+                                        12345, 80, 8000,
+                                        1000, 2000));
+    QueueDisc::Stats afterF = qF->GetStats();
+    NS_TEST_ASSERT_MSG_EQ(afterF.nTotalDroppedPacketsAfterDequeue,
+                          beforeF.nTotalDroppedPacketsAfterDequeue,
+                          "Pure-duplicate ACK + SACK should be preserved "
+                          "(no information gain; mirrors Linux equal-ACK "
+                          "+ equal-SACK no-drop case)");
+}
+
+void
+AckFilterDivergenceTest::TestEligibilityStateMachine()
+{
+    // Sub-case A: 2-eligible threshold. In conservative mode (the
+    // default), the filter drops only when TWO eligible same-flow ACKs
+    // are found in the queue; a single eligible older ACK survives.
+    // Mirrors Linux cake_ack_filter at sch_cake.c:1336-1356.
+    {
+        Ptr<FqCobaltQueueDisc> q = MakeDisc(/*aggressive=*/false);
+        q->Enqueue(MakeAckOnlyItem(Ipv4Address("10.0.0.1"),
+                                   Ipv4Address("10.0.0.2"),
+                                   12345, 80, 5000));
+        QueueDisc::Stats before = q->GetStats();
+        // Trigger: newer ACK. Only one queued candidate -> conservative
+        // mode declines to drop. (Aggressive mode would drop via the
+        // consecutive-shortcut handled in a follow-up commit.)
+        q->Enqueue(MakeAckOnlyItem(Ipv4Address("10.0.0.1"),
+                                   Ipv4Address("10.0.0.2"),
+                                   12345, 80, 6000));
+        QueueDisc::Stats after = q->GetStats();
+        NS_TEST_ASSERT_MSG_EQ(after.nTotalDroppedPacketsAfterDequeue,
+                              before.nTotalDroppedPacketsAfterDequeue,
+                              "Conservative mode must require 2 eligible "
+                              "ACKs (mirrors sch_cake.c:1336-1356)");
+    }
+
+    // Sub-case A': positive control. Same setup as A but with a third
+    // ACK that brings the walk's eligible count to 2 -- the first-saved
+    // (closest to head) MUST be dropped, not the most recent eligible.
+    {
+        Ptr<FqCobaltQueueDisc> q = MakeDisc(/*aggressive=*/false);
+        q->Enqueue(MakeAckOnlyItem(Ipv4Address("10.0.0.1"),
+                                   Ipv4Address("10.0.0.2"),
+                                   12345, 80, 5000));
+        q->Enqueue(MakeAckOnlyItem(Ipv4Address("10.0.0.1"),
+                                   Ipv4Address("10.0.0.2"),
+                                   12345, 80, 5500));
+        QueueDisc::Stats before = q->GetStats();
+        // Third arrival triggers a walk with two eligibles in the queue
+        // (5000, 5500). The first-saved (5000, closest to head) is the
+        // victim per Linux semantics (sch_cake.c:1336-1346).
+        q->Enqueue(MakeAckOnlyItem(Ipv4Address("10.0.0.1"),
+                                   Ipv4Address("10.0.0.2"),
+                                   12345, 80, 6000));
+        QueueDisc::Stats after = q->GetStats();
+        NS_TEST_ASSERT_MSG_EQ(after.nTotalDroppedPacketsAfterDequeue,
+                              before.nTotalDroppedPacketsAfterDequeue + 1,
+                              "2-eligible threshold met: first-saved ACK "
+                              "(closest to head) must be dropped");
+    }
+
+    // Sub-case B: ECE/CWR flag change resets eligibility tracking
+    // (mirrors sch_cake.c:1295-1303). Three queued ACKs whose ECE bits
+    // alternate (ECE-set, ECE-clear, ECE-set) followed by a plain
+    // trigger. The walk encounters:
+    //   - ACK1 (ECE=1) -> save, numFound=1.
+    //   - ACK2 (ECE=0) -> flags differ from saved -> reset save,
+    //     numFound back to 0 (Linux: --num_found; eligible=NULL).
+    //   - ACK3 (ECE=1) -> save again, numFound=1.
+    // Walk ends with numFound=1 -> conservative mode does NOT drop.
+    // Were the reset semantics missing, ACK2 would advance numFound to
+    // 2 and trigger a drop.
+    {
+        Ptr<FqCobaltQueueDisc> q = MakeDisc(/*aggressive=*/false);
+
+        auto makeAckWithFlags = [](uint32_t ackNum, uint8_t extraFlags) {
+            TcpHeader tcp;
+            tcp.SetSourcePort(12345);
+            tcp.SetDestinationPort(80);
+            tcp.SetAckNumber(SequenceNumber32(ackNum));
+            tcp.SetSequenceNumber(SequenceNumber32(1));
+            tcp.SetFlags(static_cast<uint8_t>(TcpHeader::ACK) | extraFlags);
+            tcp.SetWindowSize(65535);
+            Ptr<Packet> p = Create<Packet>();
+            p->AddHeader(tcp);
+            Ipv4Header ip;
+            ip.SetSource(Ipv4Address("10.0.0.1"));
+            ip.SetDestination(Ipv4Address("10.0.0.2"));
+            ip.SetProtocol(6);
+            ip.SetPayloadSize(p->GetSize());
+            return Create<Ipv4QueueDiscItem>(p, Address(), 0x0800, ip);
+        };
+
+        // ECE bit lives in TcpHeader::ECE (0x40). PSH/URG/FIN/RST are
+        // excluded by IsAckCandidate, so ECE-only is safe.
+        const uint8_t kEce = static_cast<uint8_t>(TcpHeader::ECE);
+
+        q->Enqueue(makeAckWithFlags(5000, kEce));   // ECE=1
+        q->Enqueue(makeAckWithFlags(5500, 0));      // ECE=0 (reset)
+        q->Enqueue(makeAckWithFlags(5800, kEce));   // ECE=1 (re-save)
+        QueueDisc::Stats before = q->GetStats();
+        q->Enqueue(makeAckWithFlags(6000, 0));      // trigger (plain)
+        QueueDisc::Stats after = q->GetStats();
+        NS_TEST_ASSERT_MSG_EQ(after.nTotalDroppedPacketsAfterDequeue,
+                              before.nTotalDroppedPacketsAfterDequeue,
+                              "ECE/CWR flag change must reset eligibility "
+                              "save (mirrors sch_cake.c:1295-1303)");
+    }
+}
+
+void
+AckFilterDivergenceTest::TestAggressiveConsecutiveShortcut()
+{
+    // Aggressive-mode single-eligible consecutive-shortcut. Mirrors Linux
+    // cake_ack_filter at sch_cake.c:1349-1356: after the queue walk, if
+    // only ONE eligible older same-flow ACK was found and aggressive mode
+    // is enabled, the saved eligible is dropped iff it is immediately
+    // consecutive with the triggering ACK AND their ECE/CWR flags match
+    // (so dropping preserves ECN signalling).
+    //
+    // Sub-case A: positive control. Queued ACK 5000 + trigger ACK 6000 on
+    // the same 5-tuple with no intervening packets. Conservative mode
+    // would NOT drop (only 1 eligible). Aggressive mode MUST drop because
+    // the eligible is immediately consecutive with the trigger and the
+    // flags match (both plain ACKs, ECE=0, CWR=0).
+    {
+        Ptr<FqCobaltQueueDisc> q = MakeDisc(/*aggressive=*/true);
+        q->Enqueue(MakeAckOnlyItem(Ipv4Address("10.0.0.1"),
+                                   Ipv4Address("10.0.0.2"),
+                                   12345, 80, 5000));
+        QueueDisc::Stats before = q->GetStats();
+        q->Enqueue(MakeAckOnlyItem(Ipv4Address("10.0.0.1"),
+                                   Ipv4Address("10.0.0.2"),
+                                   12345, 80, 6000));
+        QueueDisc::Stats after = q->GetStats();
+        NS_TEST_ASSERT_MSG_EQ(after.nTotalDroppedPacketsAfterDequeue,
+                              before.nTotalDroppedPacketsAfterDequeue + 1,
+                              "Aggressive mode must drop a single eligible "
+                              "ACK when immediately consecutive with the "
+                              "trigger (mirrors sch_cake.c:1349-1356)");
+    }
+
+    // Sub-case B: negative control -- conservative mode rejects the same
+    // setup. Confirms the shortcut is gated by the aggressive flag and is
+    // not a regression in conservative behaviour.
+    {
+        Ptr<FqCobaltQueueDisc> q = MakeDisc(/*aggressive=*/false);
+        q->Enqueue(MakeAckOnlyItem(Ipv4Address("10.0.0.1"),
+                                   Ipv4Address("10.0.0.2"),
+                                   12345, 80, 5000));
+        QueueDisc::Stats before = q->GetStats();
+        q->Enqueue(MakeAckOnlyItem(Ipv4Address("10.0.0.1"),
+                                   Ipv4Address("10.0.0.2"),
+                                   12345, 80, 6000));
+        QueueDisc::Stats after = q->GetStats();
+        NS_TEST_ASSERT_MSG_EQ(after.nTotalDroppedPacketsAfterDequeue,
+                              before.nTotalDroppedPacketsAfterDequeue,
+                              "Conservative mode must NOT drop on a single "
+                              "eligible (shortcut is aggressive-only)");
+    }
+
+    // Sub-case C: non-consecutive guard. Queued ACK 5000 + a different-
+    // flow item between them + trigger ACK 6000 on flow A. The eligible
+    // is NOT immediately before the trigger in the queue, so the Linux
+    // shortcut (`++elig_ack_pos == tail`) MUST refuse the drop even in
+    // aggressive mode (sch_cake.c:1352-1354).
+    {
+        Ptr<FqCobaltQueueDisc> q = MakeDisc(/*aggressive=*/true);
+        q->Enqueue(MakeAckOnlyItem(Ipv4Address("10.0.0.1"),
+                                   Ipv4Address("10.0.0.2"),
+                                   12345, 80, 5000));
+        // Intervening different-flow ACK to break consecutiveness inside
+        // the same per-flow inner queue. CAKE hashes by 5-tuple, so to
+        // land in the SAME inner queue we use a same-flow ACK but with a
+        // sequence-number high enough that it parses as a non-eligible
+        // (newer-than-trigger) intervening item.  We use a future ACK
+        // number (8000) on flow A that arrives between 5000 and the
+        // trigger 6000; by the time the trigger walks the queue, 8000 is
+        // newer-than-trigger and therefore non-eligible, breaking the
+        // ++elig_ack_pos == tail consecutiveness check.
+        q->Enqueue(MakeAckOnlyItem(Ipv4Address("10.0.0.1"),
+                                   Ipv4Address("10.0.0.2"),
+                                   12345, 80, 8000));
+        QueueDisc::Stats before = q->GetStats();
+        q->Enqueue(MakeAckOnlyItem(Ipv4Address("10.0.0.1"),
+                                   Ipv4Address("10.0.0.2"),
+                                   12345, 80, 6000));
+        QueueDisc::Stats after = q->GetStats();
+        NS_TEST_ASSERT_MSG_EQ(after.nTotalDroppedPacketsAfterDequeue,
+                              before.nTotalDroppedPacketsAfterDequeue,
+                              "Aggressive shortcut must refuse drop when "
+                              "eligible is not immediately consecutive with "
+                              "the trigger (mirrors sch_cake.c:1352-1354)");
+    }
+
+    // Sub-case D: flag-mismatch guard. Queued ECE-set ACK 5000 + plain
+    // trigger ACK 6000 on the same 5-tuple. Consecutive, single eligible,
+    // BUT the ECE/CWR flags differ -- the shortcut must refuse the drop
+    // so that ECN signalling is not lost (sch_cake.c:1354-1356).
+    {
+        Ptr<FqCobaltQueueDisc> q = MakeDisc(/*aggressive=*/true);
+
+        auto makeAckWithFlags = [](uint32_t ackNum, uint8_t extraFlags) {
+            TcpHeader tcp;
+            tcp.SetSourcePort(12345);
+            tcp.SetDestinationPort(80);
+            tcp.SetAckNumber(SequenceNumber32(ackNum));
+            tcp.SetSequenceNumber(SequenceNumber32(1));
+            tcp.SetFlags(static_cast<uint8_t>(TcpHeader::ACK) | extraFlags);
+            tcp.SetWindowSize(65535);
+            Ptr<Packet> p = Create<Packet>();
+            p->AddHeader(tcp);
+            Ipv4Header ip;
+            ip.SetSource(Ipv4Address("10.0.0.1"));
+            ip.SetDestination(Ipv4Address("10.0.0.2"));
+            ip.SetProtocol(6);
+            ip.SetPayloadSize(p->GetSize());
+            return Create<Ipv4QueueDiscItem>(p, Address(), 0x0800, ip);
+        };
+
+        const uint8_t kEce = static_cast<uint8_t>(TcpHeader::ECE);
+        q->Enqueue(makeAckWithFlags(5000, kEce));  // ECE=1 saved eligible
+        QueueDisc::Stats before = q->GetStats();
+        q->Enqueue(makeAckWithFlags(6000, 0));     // ECE=0 trigger
+        QueueDisc::Stats after = q->GetStats();
+        NS_TEST_ASSERT_MSG_EQ(after.nTotalDroppedPacketsAfterDequeue,
+                              before.nTotalDroppedPacketsAfterDequeue,
+                              "Aggressive shortcut must refuse drop when "
+                              "ECE/CWR flags differ between eligible and "
+                              "trigger (mirrors sch_cake.c:1354-1356)");
+    }
+}

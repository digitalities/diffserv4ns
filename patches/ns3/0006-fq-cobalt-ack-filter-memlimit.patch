+/**
+ * @ingroup system-tests-tc
+ *
+ * Verify ResolveHostSlot's set-associative collision resolution:
+ *   - First lookup of a given hash returns a slot index < m_flows and tags it.
+ *   - Subsequent lookup of the same hash returns the same slot (cache hit).
+ *   - Different hashes resolve to slots inside m_flows.
+ *   - When all CAKE_SET_WAYS slots in a set are tagged with different hashes,
+ *     a new hash overwrites the outer-most way (graceful slot sharing — the
+ *     set-associative analogue of Linux's cake_hash overflow behaviour).
+ */
+class FqCobaltQueueDiscHostIsoSlotResolution : public TestCase
+{
+  public:
+    FqCobaltQueueDiscHostIsoSlotResolution();
+    ~FqCobaltQueueDiscHostIsoSlotResolution() override;
+
+  private:
+    void DoRun() override;
+};
+
+FqCobaltQueueDiscHostIsoSlotResolution::FqCobaltQueueDiscHostIsoSlotResolution()
+    : TestCase("Test host-side set-associative slot resolution")
+{
+}
+
+FqCobaltQueueDiscHostIsoSlotResolution::~FqCobaltQueueDiscHostIsoSlotResolution()
+{
+}
+
+void
+FqCobaltQueueDiscHostIsoSlotResolution::DoRun()
+{
+    Ptr<FqCobaltQueueDisc> q = CreateObjectWithAttributes<FqCobaltQueueDisc>(
+        "Flows",
+        UintegerValue(64),
+        "SetWays",
+        UintegerValue(8),
+        "EnableHostIsolation",
+        BooleanValue(true));
+    q->SetQuantum(1514);
+    q->Initialize();
+
+    // Sub-case 1: cache hit. Resolve a deterministic hash twice → same slot.
+    constexpr uint32_t kHashA = 0x12345678u;
+    const uint32_t slotA1 = q->ResolveHostSlot(kHashA);
+    const uint32_t slotA2 = q->ResolveHostSlot(kHashA);
+    NS_TEST_ASSERT_MSG_EQ(slotA1, slotA2, "Same hash must resolve to same slot (cache hit)");
+    NS_TEST_ASSERT_MSG_LT(slotA1, 64u, "Resolved slot must lie within m_flows");
+
+    // Sub-case 2: a second distinct hash also resolves within m_flows.
+    constexpr uint32_t kHashB = 0x87654321u;
+    const uint32_t slotB = q->ResolveHostSlot(kHashB);
+    NS_TEST_ASSERT_MSG_LT(slotB, 64u, "Second hash must also resolve within m_flows");
+
+    // Sub-case 3: resolving kHashA again after kHashB still returns slotA1.
+    const uint32_t slotA3 = q->ResolveHostSlot(kHashA);
+    NS_TEST_ASSERT_MSG_EQ(slotA1, slotA3, "Intervening hash must not displace cached entry");
+
+    // Sub-case 4: saturate one outer set. Pick hashes that all fall into the
+    // same outer-set (by construction: hash = outerBase + arbitrary noise above
+    // m_setWays bits), then verify (a) the first m_setWays distinct hashes get
+    // distinct slots within the set, (b) the (m_setWays+1)-th hash collides
+    // back onto the outer-most way without crashing.
+    const uint32_t kSetWays = 8;
+    const uint32_t kFlows = 64;
+    // Outer base for set 0 is 0; values that map there satisfy (h % kFlows)
+    // being in [0, kSetWays). Use kFlows multiples so (h % kFlows) == 0 then
+    // perturb by 1..kSetWays-1 in the high bits to ensure distinct hash tags.
+    Ptr<FqCobaltQueueDisc> q2 = CreateObjectWithAttributes<FqCobaltQueueDisc>(
+        "Flows",
+        UintegerValue(kFlows),
+        "SetWays",
+        UintegerValue(kSetWays),
+        "EnableHostIsolation",
+        BooleanValue(true));
+    q2->SetQuantum(1514);
+    q2->Initialize();
+
+    uint32_t firstSet[kSetWays];
+    for (uint32_t i = 0; i < kSetWays; ++i)
+    {
+        // Hash whose (h % kFlows) == i — falls into outer set 0, way i.
+        uint32_t h = i + (kFlows * (i + 17u)); // distinct tags
+        firstSet[i] = q2->ResolveHostSlot(h);
+        NS_TEST_ASSERT_MSG_LT(firstSet[i], kFlows, "Slot must lie within m_flows");
+    }
+    // The first kSetWays distinct hashes must claim distinct slots (each way
+    // of the set was empty; the empty-slot search fills them in order).
+    for (uint32_t i = 1; i < kSetWays; ++i)
+    {
+        NS_TEST_ASSERT_MSG_NE(firstSet[0],
+                              firstSet[i],
+                              "Distinct hashes in same set must fill distinct ways");
+    }
+
+    // The (kSetWays+1)-th hash for the same outer set: all ways occupied →
+    // overwrites the outer-most way (slot 0). The return value is well-defined.
+    uint32_t overflow = q2->ResolveHostSlot(0u + (kFlows * 99u));
+    NS_TEST_ASSERT_MSG_EQ(overflow, 0u, "Set-full overflow must return outer-most way");
+    Simulator::Destroy();
+}
+
+/**
+ * @ingroup system-tests-tc
+ *
+ * Verify GetFlowQuantum applies the Linux reciprocal-divide modulation:
+ *   - hostLoad <= 1 → quantum unchanged (the early-exit path).
+ *   - hostLoad = 2 → quantum scaled to ~quantum/2 (within ±1 of rounding).
+ *   - hostLoad = N → quantum scaled to ~quantum/N (within ±1 of rounding).
+ *   - EnableHostIsolation=false → quantum returned unchanged regardless of hostLoad.
+ *
+ * The reciprocal-divide formula is
+ *   <tt>(quantum * kQuantumDiv[h] + dither) >> 16</tt>
+ * with <tt>kQuantumDiv[h] = 65535 / max(1, h)</tt>. Setting m_perturbation=0
+ * via the Perturbation attribute zeros the dither so the assertions can use
+ * exact arithmetic. With a non-zero dither the result is off-by-one in the
+ * direction of the ceiling, so the assertions tolerate ±1.
+ */
+class FqCobaltQueueDiscHostIsoQuantumModulation : public TestCase
+{
+  public:
+    FqCobaltQueueDiscHostIsoQuantumModulation();
+    ~FqCobaltQueueDiscHostIsoQuantumModulation() override;
+
+  private:
+    void DoRun() override;
+};
+
+FqCobaltQueueDiscHostIsoQuantumModulation::FqCobaltQueueDiscHostIsoQuantumModulation()
+    : TestCase("Test per-flow quantum modulation under varying host load")
+{
+}
+
+FqCobaltQueueDiscHostIsoQuantumModulation::~FqCobaltQueueDiscHostIsoQuantumModulation()
+{
+}
+
+void
+FqCobaltQueueDiscHostIsoQuantumModulation::DoRun()
+{
+    Ptr<FqCobaltQueueDisc> q = CreateObjectWithAttributes<FqCobaltQueueDisc>(
+        "Flows",
+        UintegerValue(64),
+        "EnableHostIsolation",
+        BooleanValue(true),
+        "Perturbation",
+        UintegerValue(0));
+    constexpr uint32_t kQuantum = 1500;
+    q->SetQuantum(kQuantum);
+    q->Initialize();
+
+    // Sub-case 1: hostLoad <= 1 → early exit, returns base quantum unchanged.
+    NS_TEST_ASSERT_MSG_EQ(q->ComputeFlowQuantumForTest(0u),
+                          kQuantum,
+                          "hostLoad=0: GetFlowQuantum must return base quantum (early exit)");
+    NS_TEST_ASSERT_MSG_EQ(q->ComputeFlowQuantumForTest(1u),
+                          kQuantum,
+                          "hostLoad=1: GetFlowQuantum must return base quantum (early exit)");
+
+    // Sub-case 2: hostLoad=2 → quantum ≈ quantum/2.
+    const uint32_t mod2 = q->ComputeFlowQuantumForTest(2u);
+    NS_TEST_ASSERT_MSG_GT_OR_EQ(mod2, (kQuantum / 2u) - 1u, "hostLoad=2: quantum ~= q/2 (low bound)");
+    NS_TEST_ASSERT_MSG_LT_OR_EQ(mod2, (kQuantum / 2u) + 1u, "hostLoad=2: quantum ~= q/2 (high bound)");
+
+    // Sub-case 3: hostLoad=8 → quantum ≈ quantum/8.
+    const uint32_t mod8 = q->ComputeFlowQuantumForTest(8u);
+    NS_TEST_ASSERT_MSG_GT_OR_EQ(mod8, (kQuantum / 8u) - 1u, "hostLoad=8: quantum ~= q/8 (low bound)");
+    NS_TEST_ASSERT_MSG_LT_OR_EQ(mod8, (kQuantum / 8u) + 1u, "hostLoad=8: quantum ~= q/8 (high bound)");
+
+    // Sub-case 4: monotonicity — larger hostLoad must yield smaller quantum.
+    NS_TEST_ASSERT_MSG_LT(mod8, mod2, "Higher hostLoad must yield smaller per-flow quantum");
+
+    // Sub-case 5: EnableHostIsolation=false → quantum returned unchanged regardless of hostLoad.
+    Ptr<FqCobaltQueueDisc> q2 = CreateObjectWithAttributes<FqCobaltQueueDisc>(
+        "Flows",
+        UintegerValue(64),
+        "EnableHostIsolation",
+        BooleanValue(false));
+    q2->SetQuantum(kQuantum);
+    q2->Initialize();
+    NS_TEST_ASSERT_MSG_EQ(q2->ComputeFlowQuantumForTest(8u),
+                          kQuantum,
+                          "EnableHostIsolation=false: hostLoad ignored, quantum unchanged");
+    NS_TEST_ASSERT_MSG_EQ(q2->ComputeFlowQuantumForTest(64u),
+                          kQuantum,
+                          "EnableHostIsolation=false: even at max hostLoad, quantum unchanged");
+    Simulator::Destroy();
+}

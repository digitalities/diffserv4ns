+/**
+ * @ingroup system-tests-tc
+ *
+ * Verify the four per-host bulk-flow counter helpers:
+ *   - Inc / Dec are monotonic for valid slot indices
+ *   - Dec on a zero counter saturates (no underflow)
+ *   - Inc saturates at m_flows (Linux's CAKE_QUEUES upper bound)
+ *   - Src and Dst counters are independent at the same slot
+ *   - Helpers are no-ops on out-of-range slot indices
+ */
+class FqCobaltQueueDiscHostIsoCounterMaintenance : public TestCase
+{
+  public:
+    FqCobaltQueueDiscHostIsoCounterMaintenance();
+    ~FqCobaltQueueDiscHostIsoCounterMaintenance() override;
+
+  private:
+    void DoRun() override;
+};
+
+FqCobaltQueueDiscHostIsoCounterMaintenance::FqCobaltQueueDiscHostIsoCounterMaintenance()
+    : TestCase("Test per-host bulk-flow counter Inc and Dec semantics")
+{
+}
+
+FqCobaltQueueDiscHostIsoCounterMaintenance::~FqCobaltQueueDiscHostIsoCounterMaintenance()
+{
+}
+
+void
+FqCobaltQueueDiscHostIsoCounterMaintenance::DoRun()
+{
+    Ptr<FqCobaltQueueDisc> q = CreateObjectWithAttributes<FqCobaltQueueDisc>(
+        "Flows",
+        UintegerValue(16),
+        "EnableHostIsolation",
+        BooleanValue(true));
+    q->SetQuantum(1514);
+    q->Initialize();
+
+    // Sub-case 1: single Inc/Dec round-trip on slot 0 (srchost side).
+    q->IncSrchostBulkFlowCount(0u);
+    NS_TEST_ASSERT_MSG_EQ(q->GetSrchostBulkFlowCountAt(0u), 1u, "Inc(0): 0 → 1");
+    q->IncSrchostBulkFlowCount(0u);
+    NS_TEST_ASSERT_MSG_EQ(q->GetSrchostBulkFlowCountAt(0u), 2u, "Inc(0): 1 → 2");
+    q->DecSrchostBulkFlowCount(0u);
+    NS_TEST_ASSERT_MSG_EQ(q->GetSrchostBulkFlowCountAt(0u), 1u, "Dec(0): 2 → 1");
+    q->DecSrchostBulkFlowCount(0u);
+    NS_TEST_ASSERT_MSG_EQ(q->GetSrchostBulkFlowCountAt(0u), 0u, "Dec(0): 1 → 0");
+
+    // Sub-case 2: Dec on zero saturates (no underflow).
+    q->DecSrchostBulkFlowCount(0u);
+    NS_TEST_ASSERT_MSG_EQ(q->GetSrchostBulkFlowCountAt(0u), 0u, "Dec on zero saturates at 0");
+
+    // Sub-case 3: Inc up to m_flows; one more must clamp at m_flows.
+    for (uint32_t i = 0; i < 16u; ++i)
+    {
+        q->IncSrchostBulkFlowCount(1u);
+    }
+    NS_TEST_ASSERT_MSG_EQ(q->GetSrchostBulkFlowCountAt(1u), 16u, "Inc(1) reaches m_flows=16");
+    q->IncSrchostBulkFlowCount(1u);
+    NS_TEST_ASSERT_MSG_EQ(q->GetSrchostBulkFlowCountAt(1u), 16u, "Inc(1) saturates at m_flows");
+
+    // Sub-case 4: dsthost counter is independent of srchost counter.
+    q->IncDsthostBulkFlowCount(0u);
+    NS_TEST_ASSERT_MSG_EQ(q->GetDsthostBulkFlowCountAt(0u), 1u, "DstInc(0): 0 → 1");
+    NS_TEST_ASSERT_MSG_EQ(q->GetSrchostBulkFlowCountAt(0u),
+                          0u,
+                          "DstInc must not touch srchost counter");
+
+    // Sub-case 5: out-of-range slot index is a silent no-op (defensive guard).
+    q->IncSrchostBulkFlowCount(99u);
+    q->DecSrchostBulkFlowCount(99u);
+    q->IncDsthostBulkFlowCount(99u);
+    q->DecDsthostBulkFlowCount(99u);
+    NS_TEST_ASSERT_MSG_EQ(q->GetSrchostBulkFlowCountAt(99u),
+                          0u,
+                          "Out-of-range slot read returns 0");
+
+    // Sub-case 6: Dec mirrors Inc symmetrically on the dsthost side too.
+    q->IncDsthostBulkFlowCount(0u);
+    q->DecDsthostBulkFlowCount(0u);
+    NS_TEST_ASSERT_MSG_EQ(q->GetDsthostBulkFlowCountAt(0u),
+                          1u,
+                          "DstInc+DstDec leaves the counter at the prior value");
+    Simulator::Destroy();
+}

+    // In-place walk over the inner CobaltQueueDisc's InternalQueue.
+    // Mirrors Linux cake_ack_filter() head->tail-1 traversal at
+    // sch_cake.c:1258-1260. The new arrival (the "triggering ACK") has
+    // ALREADY been enqueued at tail by the post-enqueue call site in
+    // DoEnqueue, so we walk Begin() up to (but not including) the last
+    // item.
+    auto it = internal->Begin();
+    auto last = internal->End();
+    if (it == last)
+    {
+        return;
+    }
+    // Step "last" back by one to point at the tail (the new arrival).
+    auto tail = last;
+    --tail;
+    if (it == tail)
+    {
+        // Only the triggering item present — no candidates.
+        return;
+    }
+
+    // Extract the trigger's SACK ranges once so per-queued comparisons
+    // do not re-parse the tail. Mirrors Linux cake_ack_filter caching
+    // the triggering ACK's SACK pointer before the inner-loop walk
+    // (sch_cake.c:1318-1330).
+    std::vector<std::pair<uint32_t, uint32_t>> triggerSackRanges;
+    ExtractSackRanges(*tail, triggerSackRanges);

+uint32_t
+FqCobaltQueueDisc::ResolveHostSlot(uint32_t hostHash)
+{
+    NS_LOG_FUNCTION(this << hostHash);
+
+    uint32_t h = (hostHash % m_flows);
+    uint32_t innerHash = h % m_setWays;
+    uint32_t outerHash = h - innerHash;
+
+    // Cache-hit search: any way in the set already tagged with this host hash
+    // resolves immediately. Set-associative semantics mean a host is "in the
+    // set" only if a way carries its tag.
+    for (uint32_t i = outerHash; i < outerHash + m_setWays; ++i)
+    {
+        if (m_hostTags[i] == hostHash)
+        {
+            return i;
+        }
+    }
+
+    // Empty-slot search: an unoccupied way is one whose tag is the sentinel
+    // (zero) AND whose per-host bulk counters are both zero. Linux's cake_hash
+    // uses a similar "no bulk flows" predicate; reusing it here avoids carrying
+    // a separate occupancy bitset.
+    for (uint32_t i = outerHash; i < outerHash + m_setWays; ++i)
+    {
+        if (m_hostTags[i] == 0u && m_hosts[i].srchost_bulk_flow_count == 0u &&
+            m_hosts[i].dsthost_bulk_flow_count == 0u)
+        {
+            m_hostTags[i] = hostHash;
+            return i;
+        }
+    }
+
+    // All ways occupied: overwrite the outer-most way so the new arrival shares
+    // a host bucket with the previous occupant. Counters are intentionally NOT
+    // cleared; the bulk-flow-count Inc/Dec maintenance preserves consistency
+    // for whichever flow is still active. Set-associative slot sharing under
+    // hash saturation — analogous to Linux cake_hash's overflow behaviour.
+    m_hostTags[outerHash] = hostHash;
+    return outerHash;
+}

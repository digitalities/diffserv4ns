+bool
+FqCobaltQueueDisc::FqCobaltMemLimitEvict()
+{
+    NS_LOG_FUNCTION(this);
+
+    // Linear walk to find the longest flow queue by byte count. Linux uses
+    // a max-heap (overflow_heap, rebuilt opportunistically) for amortised
+    // O(log N); our flow set is bounded by m_flows (~1024), so a linear
+    // walk per eviction is acceptable in this context and matches the
+    // FqCobaltDrop fat-flow lookup pattern.
+    Ptr<QueueDiscClass> victim;
+    uint32_t maxBytes = 0;
+    for (uint32_t i = 0; i < GetNQueueDiscClasses(); ++i)
+    {
+        Ptr<QueueDiscClass> cls = GetQueueDiscClass(i);
+        if (!cls)
+        {
+            continue;
+        }
+        Ptr<QueueDisc> inner = cls->GetQueueDisc();
+        if (!inner)
+        {
+            continue;
+        }
+        const uint32_t bytes = inner->GetNBytes();
+        if (bytes > maxBytes)
+        {
+            maxBytes = bytes;
+            victim = cls;
+        }
+    }
+
+    if (!victim)
+    {
+        return false;
+    }
+
+    Ptr<QueueDisc> inner = victim->GetQueueDisc();
+    Ptr<QueueBase> internalBase = inner->GetInternalQueue(0);
+    Ptr<Queue<QueueDiscItem>> internal = DynamicCast<Queue<QueueDiscItem>>(internalBase);
+    if (!internal || internal->IsEmpty())

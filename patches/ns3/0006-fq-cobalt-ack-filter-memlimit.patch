+void
+FqCobaltQueueDisc::IncSrchostBulkFlowCount(uint32_t srchostIdx)
+{
+    NS_LOG_FUNCTION(this << srchostIdx);
+    if (srchostIdx >= m_hosts.size())
+    {
+        return;
+    }
+    // Saturate at m_flows. Linux's WARN_ON_ONCE(... >= CAKE_QUEUES) guards the
+    // production path; the per-host count cannot exceed the per-flow count by
+    // construction, so this clamp is defensive against accounting bugs only.
+    if (m_hosts[srchostIdx].srchost_bulk_flow_count < m_flows)
+    {
+        ++m_hosts[srchostIdx].srchost_bulk_flow_count;
+    }
+}
+
+void
+FqCobaltQueueDisc::DecSrchostBulkFlowCount(uint32_t srchostIdx)
+{
+    NS_LOG_FUNCTION(this << srchostIdx);
+    if (srchostIdx >= m_hosts.size())
+    {
+        return;
+    }
+    // Saturate at zero. Linux's WARN_ON_ONCE(... == 0) guards the dec path.
+    if (m_hosts[srchostIdx].srchost_bulk_flow_count > 0u)
+    {
+        --m_hosts[srchostIdx].srchost_bulk_flow_count;
+    }
+}

+/**
+ * Three-way wrap-aware SACK-range comparator. Mirrors Linux
+ * cake_tcph_sack_compare at sch_cake.c:1318-1330.
+ *
+ *   Returns -1 if the queued ACK reports SACK information the trigger
+ *          does not (some queued block is not fully covered by any
+ *          trigger block) — i.e. the queued is a "SACK-superset" and
+ *          MUST be preserved.
+ *   Returns +1 if the trigger reports strictly more SACK information
+ *          than the queued (every queued block is contained in some
+ *          trigger block AND the trigger reports at least one block the
+ *          queued does not cover, OR the trigger reports any blocks
+ *          while the queued reports none).
+ *   Returns  0 if the two SACK reports cover exactly the same set of
+ *          ranges (mutually contained, or both empty).
+ *
+ * "Contained" uses Linux's wrap-aware !before / !after seq comparisons
+ * (sch_cake.c:1108): block [aBegin, aEnd) is contained in
+ * [bBegin, bEnd) iff !before(aBegin, bBegin) && !after(aEnd, bEnd),
+ * which in @c NotAfter32 terms is
+ * `NotAfter32(bBegin, aBegin) && NotAfter32(aEnd, bEnd)`. A raw
+ * unsigned @c <=/>= comparison is wrong as soon as the SACK seq
+ * numbers approach wrap.
+ */
+static int
+SackRangesCompare(const std::vector<std::pair<uint32_t, uint32_t>>& queuedRanges,
+                  const std::vector<std::pair<uint32_t, uint32_t>>& triggerRanges)
+{
+    auto containedIn = [](const std::pair<uint32_t, uint32_t>& a,
+                          const std::vector<std::pair<uint32_t, uint32_t>>& bs) -> bool {
+        for (const auto& b : bs)
+        {
+            // !before(a.first, b.first) && !after(a.second, b.second)
+            if (NotAfter32(b.first, a.first) && NotAfter32(a.second, b.second))
+            {
+                return true;
+            }
+        }
+        return false;
+    };
+
+    bool queuedHasUncovered = false;
+    for (const auto& q : queuedRanges)
+    {
+        if (!containedIn(q, triggerRanges))
+        {
+            queuedHasUncovered = true;
+            break;
+        }
+    }
+    bool triggerHasUncovered = false;
+    for (const auto& t : triggerRanges)
+    {
+        if (!containedIn(t, queuedRanges))
+        {
+            triggerHasUncovered = true;
+            break;
+        }
+    }
+
+    if (queuedHasUncovered)
+    {
+        return -1; // queued SACKs information trigger does not -- preserve
+    }
+    if (triggerHasUncovered)
+    {
+        return +1; // trigger SACKs strictly more -- queued droppable
+    }
+    return 0; // equivalent SACK reports
+}

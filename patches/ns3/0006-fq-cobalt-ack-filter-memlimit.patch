+/**
+ * Extract the SACK blocks from the TCP header of @p item, appending each
+ * (begin, end) pair (in host byte order) to @p ranges. The vector is left
+ * empty when the item carries no SACK option, when the item is not a
+ * well-formed TCP segment, or when the SACK option length is invalid.
+ *
+ * Mirrors the SACK-block iteration in Linux cake_tcph_sack_compare at
+ * net/sched/sch_cake.c:1318-1330.
+ */
+static void
+ExtractSackRanges(Ptr<const QueueDiscItem> item, std::vector<std::pair<uint32_t, uint32_t>>& ranges)
+{
+    ranges.clear();
+    if (!item)
+    {
+        return;
+    }
+    Ptr<Packet> pkt = item->GetPacket();
+    if (!pkt || pkt->GetSize() < 20)
+    {
+        return;
+    }
+    uint8_t buf[60]; // max TCP header size with options
+    const uint32_t copyLen = std::min<uint32_t>(pkt->GetSize(), sizeof(buf));
+    pkt->CopyData(buf, copyLen);
+    const uint32_t tcpHdrBytes = ((buf[12] >> 4) & 0x0F) * 4;
+    if (tcpHdrBytes < 20 || tcpHdrBytes > copyLen)
+    {
+        return;
+    }
+    uint32_t off = 20;
+    while (off < tcpHdrBytes)
+    {
+        const uint8_t kind = buf[off];
+        if (kind == 0) // EOL
+        {
+            break;
+        }
+        if (kind == 1) // NOP
+        {
+            ++off;
+            continue;
+        }
+        if (off + 1 >= tcpHdrBytes)
+        {
+            break;
+        }
+        const uint8_t optLen = buf[off + 1];
+        if (optLen < 2 || off + optLen > tcpHdrBytes)
+        {
+            break;
+        }
+        if (kind == 5) // SACK: length = 2 + N*8, N in [1,4]
+        {
+            if (optLen >= 10 && ((optLen - 2) % 8) == 0)
+            {
+                const uint32_t nBlocks = (optLen - 2) / 8;
+                for (uint32_t i = 0; i < nBlocks; ++i)
+                {
+                    const uint32_t blockOff = off + 2 + i * 8;
+                    const uint32_t begin = (static_cast<uint32_t>(buf[blockOff]) << 24) |
+                                           (static_cast<uint32_t>(buf[blockOff + 1]) << 16) |
+                                           (static_cast<uint32_t>(buf[blockOff + 2]) << 8) |
+                                           static_cast<uint32_t>(buf[blockOff + 3]);
+                    const uint32_t end = (static_cast<uint32_t>(buf[blockOff + 4]) << 24) |
+                                         (static_cast<uint32_t>(buf[blockOff + 5]) << 16) |
+                                         (static_cast<uint32_t>(buf[blockOff + 6]) << 8) |
+                                         static_cast<uint32_t>(buf[blockOff + 7]);
+                    ranges.emplace_back(begin, end);
+                }
+            }
+        }
+        off += optLen;
+    }
+}

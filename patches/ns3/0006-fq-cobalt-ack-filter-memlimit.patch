+
+bool
+FqCobaltQueueDisc::IsAckCandidate(Ptr<const QueueDiscItem> item,
+                                  bool aggressive,
+                                  uint32_t& ackNumOut,
+                                  uint32_t& tstampOut,
+                                  uint32_t& tsecrOut,
+                                  bool& hasTsOut)
+{
+    // Queued-side disqualifying flag mask: SYN | FIN | RST | URG | PSH.
+    // Mirrors Linux cake_tcph_may_drop at sch_cake.c:1310-1316.
+    constexpr uint8_t kQueuedStateFlags =
+        0x02 /*SYN*/ | 0x01 /*FIN*/ | 0x04 /*RST*/ | 0x20 /*URG*/ | 0x08 /*PSH*/;
+    // The aggressive flag is reserved for ScanAndDropRedundant's
+    // eligibility state machine; it does not change candidacy here.
+    (void)aggressive;
+    return ParseAckFilterPacket(item, kQueuedStateFlags, ackNumOut, tstampOut, tsecrOut, hasTsOut);
+}
+
+bool
+FqCobaltQueueDisc::IsValidAckTrigger(Ptr<const QueueDiscItem> item,
+                                     uint32_t& ackNumOut,
+                                     uint32_t& tstampOut,
+                                     uint32_t& tsecrOut,
+                                     bool& hasTsOut)
+{
+    // Trigger-side disqualifying flag mask: SYN only. Linux's
+    // cake_ack_filter at sch_cake.c:1249-1251 admits triggers carrying
+    // PSH / URG / FIN / RST (those flags only disqualify queued items as
+    // drop targets, not triggers); the trigger path's only flag-based
+    // exclusion is the SYN check.
+    constexpr uint8_t kTriggerStateFlags = 0x02 /*SYN*/;
+    return ParseAckFilterPacket(item, kTriggerStateFlags, ackNumOut, tstampOut, tsecrOut, hasTsOut);
+}

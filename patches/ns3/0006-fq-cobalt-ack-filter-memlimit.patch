+/**
+ * @ingroup system-tests-tc
+ *
+ * Verify ExtractFlowKey's TCP-only contract: returns true on a well-formed
+ * TCP segment with correct port round-trip; returns false on a non-TCP
+ * item whose inner-packet first four bytes happen to be port-shaped
+ * (e.g. UDP, which shares the src/dst-port layout). The IP protocol byte
+ * gate makes the function self-defending against callers that bypass
+ * IsAckCandidate / IsValidAckTrigger.
+ */
+class FqCobaltQueueDiscExtractFlowKeyTcpOnly : public TestCase
+{
+  public:
+    FqCobaltQueueDiscExtractFlowKeyTcpOnly()
+        : TestCase("ExtractFlowKey returns false on non-TCP items "
+                   "(IP protocol gate, latent contract defense)")
+    {
+    }
+
+    ~FqCobaltQueueDiscExtractFlowKeyTcpOnly() override = default;
+
+  private:
+    void DoRun() override
+    {
+        const Ipv4Address srcA("10.1.1.1");
+        const Ipv4Address dstA("10.2.2.2");
+        constexpr uint16_t kSport = 1024;
+        constexpr uint16_t kDport = 80;
+
+        {
+            Ptr<Ipv4QueueDiscItem> tcp = MakeAckOnlyItem(srcA, dstA, kSport, kDport, 100);
+            FqCobaltQueueDisc::AckFilterFlowKey key{};
+            const bool ok = FqCobaltQueueDisc::ExtractFlowKey(tcp, key);
+            NS_TEST_ASSERT_MSG_EQ(ok, true,
+                                  "ExtractFlowKey must return true on a well-formed TCP segment");
+            NS_TEST_ASSERT_MSG_EQ(key.srcPort, kSport, "TCP src port must round-trip");
+            NS_TEST_ASSERT_MSG_EQ(key.dstPort, kDport, "TCP dst port must round-trip");
+        }
+
+        {
+            Ptr<Ipv4QueueDiscItem> udp = MakeUdpItem(srcA, dstA, kSport, kDport);
+            FqCobaltQueueDisc::AckFilterFlowKey key{};
+            const bool ok = FqCobaltQueueDisc::ExtractFlowKey(udp, key);
+            NS_TEST_ASSERT_MSG_EQ(ok, false,
+                                  "ExtractFlowKey must return false on a non-TCP item; "
+                                  "IP protocol byte (17 for UDP) is the self-defending gate");
+        }
+
+        {
+            // IPv6 sub-case. Ipv6QueueDiscItem inherits the base
+            // QueueDiscItem::GetIpProtocol() default (returns 0; no L3
+            // context exposed at the base), so all IPv6 items are
+            // rejected by ExtractFlowKey under the new gate. This is
+            // the conservative default — the existing
+            // port-bytes layout in ExtractFlowKey assumes the IPv4 +
+            // L4 inner-Packet shape; IPv6 + TCP coverage would need a
+            // separate Ipv6QueueDiscItem override of GetIpProtocol
+            // plus extension-header handling, intentionally deferred.
+            //
+            // Item carries IPv6 + TCP semantics (Next Header 6); the
+            // test verifies the rejection happens at the protocol gate
+            // regardless of L4 content.
+            TcpHeader tcp;
+            tcp.SetSourcePort(kSport);
+            tcp.SetDestinationPort(kDport);
+            tcp.SetAckNumber(SequenceNumber32(100));
+            tcp.SetSequenceNumber(SequenceNumber32(1));
+            tcp.SetFlags(TcpHeader::ACK);
+            tcp.SetWindowSize(65535);
+            Ptr<Packet> p = Create<Packet>();
+            p->AddHeader(tcp);
+            Ipv6Header ip6;
+            ip6.SetSource(Ipv6Address("2001:db8::1"));
+            ip6.SetDestination(Ipv6Address("2001:db8::2"));
+            ip6.SetNextHeader(6);
+            ip6.SetPayloadLength(static_cast<uint16_t>(p->GetSize()));
+            Ptr<Ipv6QueueDiscItem> v6 =
+                Create<Ipv6QueueDiscItem>(p, Address(), 0x86DD, ip6);
+
+            FqCobaltQueueDisc::AckFilterFlowKey key{};
+            const bool ok = FqCobaltQueueDisc::ExtractFlowKey(v6, key);
+            NS_TEST_ASSERT_MSG_EQ(ok, false,
+                                  "ExtractFlowKey must return false on an IPv6 item; "
+                                  "Ipv6QueueDiscItem inherits base GetIpProtocol()=0, so "
+                                  "the IP-protocol gate rejects (conservative default).");
+        }
+
+        Simulator::Destroy();
+    }
+};

+/**
+ * @ingroup system-tests-tc
+ *
+ * Build a minimal IPv4 Ipv4QueueDiscItem suitable for exercising the
+ * polymorphic host-hash virtuals (HashSrcHost / HashDstHost). The transport
+ * protocol and ports are irrelevant for these methods, which read only the
+ * IPv4 source and destination addresses, so a bare 100-byte payload is enough.
+ */
+static Ptr<Ipv4QueueDiscItem>
+MakeIpv4HostHashItem(Ipv4Address src, Ipv4Address dst)
+{
+    Ptr<Packet> p = Create<Packet>(100);
+    Ipv4Header ip;
+    ip.SetSource(src);
+    ip.SetDestination(dst);
+    ip.SetProtocol(17);
+    ip.SetPayloadSize(p->GetSize());
+    return Create<Ipv4QueueDiscItem>(p, Address(), 0x0800, ip);
+}
+
+/**
+ * @ingroup system-tests-tc
+ *
+ * Build a minimal IPv6 Ipv6QueueDiscItem suitable for exercising the
+ * polymorphic host-hash virtuals on the IPv6 subclass. Analogous to
+ * MakeIpv4HostHashItem; protocol number 17 (UDP) and 100-byte payload.
+ */
+static Ptr<Ipv6QueueDiscItem>
+MakeIpv6HostHashItem(Ipv6Address src, Ipv6Address dst)
+{
+    Ptr<Packet> p = Create<Packet>(100);
+    Ipv6Header ip;
+    ip.SetSource(src);
+    ip.SetDestination(dst);
+    ip.SetNextHeader(17);
+    ip.SetPayloadLength(static_cast<uint16_t>(p->GetSize()));
+    return Create<Ipv6QueueDiscItem>(p, Address(), 0x86DD, ip);
+}

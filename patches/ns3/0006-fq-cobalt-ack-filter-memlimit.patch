+/**
+ * @ingroup system-tests-tc
+ *
+ * Verify end-to-end per-host fairness under HostIsolationMode::Triple.
+ *
+ * Topology: 4 source hosts (10.1.1.1 .. 10.1.1.4), each generating 2 distinct
+ * bulk flows by varying the destination address (10.2.2.0 and 10.2.2.3). All
+ * 8 flows enqueue 32 packets each (256 total). Host hashing under Triple mode
+ * keys on max(srchost, dsthost); since all flows from a given source share
+ * the same source IP, the per-host counters bucket two flows per source host.
+ *
+ * Expected outcome: after full drain, each of the 4 source hosts receives
+ * approximately 25% of the dequeued byte total, NOT 1/8 (12.5%) which would
+ * be naive per-flow fairness. The reciprocal-divide formula
+ *   flow_quantum = base_quantum * (65535 / host_load) >> 16
+ * reduces each flow's quantum when its host has multiple active bulk flows,
+ * restoring per-host equity.
+ *
+ * Tolerance: each source-host's share must lie within 0.25 +/- 0.10
+ * (i.e. [0.15, 0.35]). The tolerance accommodates the discrete quantum
+ * accounting and the integer reciprocal-divide rounding without masking a
+ * regression to per-flow fairness (which would land each source-host at
+ * 0.25 exactly only by coincidence; the diagnostic is that without
+ * modulation the *flows* would be equal and each host's share would
+ * stay near 0.25 as well in this symmetric 2-flows-per-host setup, so
+ * the assertion is primarily a smoke test that integration did not regress
+ * the symmetric case).
+ */
+class FqCobaltQueueDiscHostIsoTripleFairness : public TestCase
+{
+  public:
+    FqCobaltQueueDiscHostIsoTripleFairness();
+    ~FqCobaltQueueDiscHostIsoTripleFairness() override;
+
+  private:
+    void DoRun() override;
+};
+
+FqCobaltQueueDiscHostIsoTripleFairness::FqCobaltQueueDiscHostIsoTripleFairness()
+    : TestCase("Test Triple-mode per-host fairness with 4 sources and 2 flows each")
+{
+}
+
+FqCobaltQueueDiscHostIsoTripleFairness::~FqCobaltQueueDiscHostIsoTripleFairness()
+{
+}
+
+void
+FqCobaltQueueDiscHostIsoTripleFairness::DoRun()
+{
+    Ptr<FqCobaltQueueDisc> q = CreateObjectWithAttributes<FqCobaltQueueDisc>(
+        "Flows",
+        UintegerValue(64),
+        "EnableHostIsolation",
+        BooleanValue(true),
+        "Perturbation",
+        UintegerValue(0));
+    q->SetQuantum(1514);
+    q->Initialize();
+    q->SetHostIsolationMode(FqCobaltQueueDisc::HostIsolationMode::Triple);
+
+    // 4 source hosts, 2 flows each (distinct destinations for distinct 5-tuples).
+    const Ipv4Address kSources[4] = {
+        Ipv4Address("10.1.1.1"),
+        Ipv4Address("10.1.1.2"),
+        Ipv4Address("10.1.1.3"),
+        Ipv4Address("10.1.1.4"),
+    };
+    const Ipv4Address kDests[2] = {
+        Ipv4Address("10.2.2.0"),
+        Ipv4Address("10.2.2.3"),
+    };
+    const uint32_t kPacketsPerFlow = 32;
+
+    // Enqueue 32 packets per flow: 4 sources * 2 dests * 32 = 256 packets.
+    for (uint32_t s = 0; s < 4u; ++s)
+    {
+        for (uint32_t f = 0; f < 2u; ++f)
+        {
+            for (uint32_t i = 0; i < kPacketsPerFlow; ++i)
+            {
+                q->Enqueue(MakeIpv4HostHashItem(kSources[s], kDests[f]));
+            }
+        }
+    }
+
+    // Dequeue all packets, tally bytes per source-host (keyed on last octet).
+    uint64_t bytesPerSrc[4] = {0, 0, 0, 0};
+    uint64_t totalBytes = 0;
+    while (true)
+    {
+        Ptr<QueueDiscItem> item = q->Dequeue();
+        if (!item)
+        {
+            break;
+        }
+        Ptr<Ipv4QueueDiscItem> ipItem = DynamicCast<Ipv4QueueDiscItem>(item);
+        NS_TEST_ASSERT_MSG_NE(ipItem, nullptr, "Dequeued item must be an Ipv4QueueDiscItem");
+        uint32_t srcRaw = ipItem->GetHeader().GetSource().Get();
+        uint32_t lastOctet = srcRaw & 0xffu;
+        NS_TEST_ASSERT_MSG_GT(lastOctet, 0u, "Source last-octet must be in {1..4}");
+        NS_TEST_ASSERT_MSG_LT(lastOctet, 5u, "Source last-octet must be in {1..4}");
+        uint64_t sz = item->GetSize();
+        bytesPerSrc[lastOctet - 1] += sz;
+        totalBytes += sz;
+    }
+
+    NS_TEST_ASSERT_MSG_GT(totalBytes, 0u, "Must have dequeued at least one byte");
+
+    // Assert each source-host's share lies within 0.25 +/- 0.10.
+    for (uint32_t s = 0; s < 4u; ++s)
+    {
+        double share = static_cast<double>(bytesPerSrc[s]) / static_cast<double>(totalBytes);
+        NS_TEST_ASSERT_MSG_GT_OR_EQ(
+            share,
+            0.15,
+            "Source-host " << (s + 1) << " share " << share << " below 0.15 lower bound");
+        NS_TEST_ASSERT_MSG_LT_OR_EQ(
+            share,
+            0.35,
+            "Source-host " << (s + 1) << " share " << share << " above 0.35 upper bound");
+    }
+
+    Simulator::Destroy();
+}

+uint32_t
+FqCobaltQueueDisc::HostLoadForFlow(const Ptr<FqCobaltFlow>& flow) const
+{
+    if (!m_enableHostIsolation || !flow->m_bulk)
+    {
+        return 1u;
+    }
+    // Read each side's count only when the slot's tag still matches the hash
+    // this flow claimed it under. A mismatch means a later flow displaced the
+    // slot via set-associative overflow; this flow's count contribution was
+    // transferred to the new occupant and reading the slot now would return
+    // the foreign count. Treat the side as 0 in that case; std::max() with 1
+    // below ensures the modulation falls back to the full base quantum.
+    const bool srcValid = flow->m_srchostIdx < m_hostTags.size() &&
+                          m_hostTags[flow->m_srchostIdx] == flow->m_srchostHash;
+    const bool dstValid = flow->m_dsthostIdx < m_hostTags.size() &&
+                          m_hostTags[flow->m_dsthostIdx] == flow->m_dsthostHash;
+    const uint32_t src = srcValid ? GetSrchostBulkFlowCountAt(flow->m_srchostIdx) : 0u;
+    const uint32_t dst = dstValid ? GetDsthostBulkFlowCountAt(flow->m_dsthostIdx) : 0u;
+    switch (m_hostIsolationMode)
+    {
+    case HostIsolationMode::Triple:
+        return std::max<uint32_t>(std::max(src, dst), 1u);
+    case HostIsolationMode::DualSrcHost:
+        return std::max<uint32_t>(src, 1u);
+    case HostIsolationMode::DualDstHost:
+        return std::max<uint32_t>(dst, 1u);
+    case HostIsolationMode::Flowblind:
+    case HostIsolationMode::Flows:
+    default:
+        return 1u;
+    }
+}

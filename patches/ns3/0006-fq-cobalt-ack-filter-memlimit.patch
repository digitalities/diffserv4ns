+/**
+ * @brief Wrap-aware "queued is not after trigger" comparison on 32-bit sequence
+ * fields (TCP timestamps, cumulative ACK numbers).
+ *
+ * Returns true iff @p a is at-or-before @p b modulo 2^32. Mirrors the Linux
+ * `before()` / `!after()` idiom used throughout net/tcp.h and sch_cake.c
+ * (e.g. cake_tcph_may_drop at sch_cake.c:1196-1198 wraps the TS-eligibility
+ * predicate in `!after(qTstamp, triggerTstamp) && !after(qTsecr, triggerTsecr)`).
+ *
+ * Implementation: cast the unsigned difference to signed int32_t — the wrap
+ * arithmetic gives a half-space interpretation that is correct for any pair
+ * within 2^31 of each other, which covers the entire viable lifetime of an
+ * in-flight TCP sequence value.
+ */
+inline bool
+NotAfter32(uint32_t a, uint32_t b)
+{
+    return static_cast<int32_t>(a - b) <= 0;
+}
+
+/**
+ * @brief Shared TCP-byte parser for ACK-filter candidacy and triggership.
+ *
+ * Both @c IsAckCandidate (queued-side gate) and @c IsValidAckTrigger
+ * (trigger-side gate) need the same wire-level decoding: TCP header bounds,
+ * cumulative ACK number, flags, TCP option walk (rejecting unknown options
+ * per Linux cake_tcph_may_drop), TS extraction, payload-length check. The
+ * only difference is which TCP-flag mask disqualifies the item:
+ *   - trigger-side rejects SYN only (sch_cake.c:1249-1251);
+ *   - queued-side rejects SYN | FIN | RST | URG | PSH (sch_cake.c:1310-1316).
+ *
+ * Returns true on a wire-valid ACK-only segment (payload == 0) with no
+ * disqualifying flag in @p stateFlagMask and no unknown TCP options.
+ */
+bool
+ParseAckFilterPacket(Ptr<const QueueDiscItem> item,
+                     uint8_t stateFlagMask,
+                     uint32_t& ackNumOut,
+                     uint32_t& tstampOut,
+                     uint32_t& tsecrOut,
+                     bool& hasTsOut)
+{
+    hasTsOut = false;
+    if (!item)
+    {
+        return false;
+    }
+    Ptr<Packet> pkt = item->GetPacket();
+    if (!pkt)
+    {
+        return false;
+    }
+    // The inner Packet of an Ipv4QueueDiscItem starts with the TCP header
+    // (the IPv4 header lives separately in the concrete subclass and is
+    // outside the bytes we inspect here). Need 20 bytes minimum for a
+    // standard TCP header.
+    const uint32_t kMinTcpLen = 20;
+    if (pkt->GetSize() < kMinTcpLen)
+    {
+        return false;
+    }
+    uint8_t buf[60]; // max TCP header size with options
+    const uint32_t copyLen = std::min<uint32_t>(pkt->GetSize(), sizeof(buf));
+    pkt->CopyData(buf, copyLen);
+
+    // TCP source / destination ports (bytes 0-3); cumulative ACK number
+    // (bytes 8-11); data offset in high nibble of byte 12; flags in byte 13.
+    ackNumOut = (static_cast<uint32_t>(buf[8]) << 24) | (static_cast<uint32_t>(buf[9]) << 16) |
+                (static_cast<uint32_t>(buf[10]) << 8) | buf[11];
+
+    const uint32_t tcpHdrBytes = ((buf[12] >> 4) & 0x0F) * 4;
+    if (tcpHdrBytes < 20 || tcpHdrBytes > copyLen)
+    {
+        return false;
+    }
+    const uint8_t flags = buf[13];
+    if ((flags & stateFlagMask) != 0)
+    {
+        return false;
+    }
+    // ACK flag must be set.
+    if ((flags & 0x10) == 0)
+    {
+        return false;
+    }
+    // Walk TCP options. Linux cake_tcph_may_drop accepts only kind ∈
+    // {0 EOL, 1 NOP, 5 SACK, 8 Timestamp}; any other kind (MSS=2,
+    // WindowScale=3, SackPermitted=4, TFO=34, Experimental=254, etc.)
+    // causes the trigger / queued-item to be rejected outright (default
+    // branch of the switch at net/sched/sch_cake.c cake_tcph_may_drop).
+    // Rejecting on unknown options is conservative-safe: ACKs carrying
+    // unfamiliar TCP options may convey information our filter cannot
+    // reason about, so we never drop them.
+    //
+    // The TS option (kind=8, length=10, payload [tsval:4][tsecr:4]) is
+    // extracted into @p tstampOut / @p tsecrOut / @p hasTsOut for the
+    // downstream wrap-aware TS comparison in ScanAndDropRedundant
+    // (mirrors Linux cake_tcph_get_tstamp at sch_cake.c:1131-1143 +
+    // cake_tcph_may_drop TIMESTAMP branch at sch_cake.c:1196-1198).
+    // SACK options (kind=5) do not disqualify either; the SACK-range
+    // subset check is performed by ScanAndDropRedundant on a queued /
+    // trigger basis (mirrors Linux cake_tcph_sack_compare at
+    // sch_cake.c:1061-1129).
+    if (tcpHdrBytes > 20)
+    {
+        uint32_t off = 20;
+        while (off < tcpHdrBytes)
+        {
+            const uint8_t kind = buf[off];
+            if (kind == 0) // EOL — end of options
+            {
+                break;
+            }
+            if (kind == 1) // NOP — pad byte
+            {
+                ++off;
+                continue;
+            }
+            if (off + 1 >= tcpHdrBytes)
+            {
+                return false; // option header truncated
+            }
+            const uint8_t optLen = buf[off + 1];
+            if (optLen < 2 || off + optLen > tcpHdrBytes)
+            {
+                return false; // malformed / truncated option length
+            }
+            if (kind == 8 && optLen == 10) // Timestamp (well-formed)
+            {
+                tstampOut = (static_cast<uint32_t>(buf[off + 2]) << 24) |
+                            (static_cast<uint32_t>(buf[off + 3]) << 16) |
+                            (static_cast<uint32_t>(buf[off + 4]) << 8) |
+                            static_cast<uint32_t>(buf[off + 5]);
+                tsecrOut = (static_cast<uint32_t>(buf[off + 6]) << 24) |
+                           (static_cast<uint32_t>(buf[off + 7]) << 16) |
+                           (static_cast<uint32_t>(buf[off + 8]) << 8) |
+                           static_cast<uint32_t>(buf[off + 9]);
+                hasTsOut = true;
+            }
+            else if (kind == 19) // TCPOPT_MD5SIG (RFC 2385): does not influence
+                                 // ACK / ECN / TS state; treat as benign and
+                                 // skip its bytes without rejecting the
+                                 // packet (mirrors Linux sch_cake.c:1182).
+            {
+                off += optLen;
+                continue;
+            }
+            else if (kind != 5) // SACK (kind=5) is allowed; reject anything else
+            {
+                return false;
+            }
+            off += optLen;
+        }
+    }
+
+    // Payload bytes = total Packet size minus TCP header.
+    const uint32_t totalBytes = pkt->GetSize();
+    if (totalBytes < tcpHdrBytes)
+    {
+        return false;
+    }
+    const uint32_t payload = totalBytes - tcpHdrBytes;
+    return payload == 0;
+}

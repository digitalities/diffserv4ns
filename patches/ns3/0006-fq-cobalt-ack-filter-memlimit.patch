+uint32_t
+FqCobaltQueueDisc::GetFlowQuantum(uint32_t hostLoad) const
+{
+    if (!m_enableHostIsolation || hostLoad <= 1u)
+    {
+        return m_quantum;
+    }
+    NS_ASSERT_MSG(!m_quantumDiv.empty(),
+                  "GetFlowQuantum called before Initialize: m_quantumDiv is empty");
+    // Clamp host_load to the lookup table's domain; m_quantumDiv has m_flows+1
+    // entries (indices 0..m_flows). Clamping protects pathological callers; in
+    // practice the per-host counter cannot exceed m_flows by construction.
+    const uint32_t clamped = std::min<uint32_t>(hostLoad, m_flows);
+    // Linux uses get_random_u16() for dither; we use a deterministic dither
+    // derived from m_perturbation so the modulation is reproducible across
+    // identical-seed simulation runs (a property tests rely on).
+    const uint32_t dither = m_perturbation & 0xffffu;
+    const uint64_t scaled =
+        (static_cast<uint64_t>(m_quantum) * m_quantumDiv[clamped] + dither) >> 16;
+    return static_cast<uint32_t>(scaled);
+}
+
+uint32_t
+FqCobaltQueueDisc::ComputeFlowQuantumForTest(uint32_t hostLoad) const
+{
+    return GetFlowQuantum(hostLoad);
+}

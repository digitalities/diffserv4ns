+/**
+ * @ingroup system-tests-tc
+ *
+ * Verify that with EnableHostIsolation=false, FqCobaltQueueDisc produces
+ * byte-identical dispatch ordering to a default-constructed instance. This
+ * is the formal byte-identity guarantee underlying the off-path acceptance
+ * gate: the host-isolation code path must remain dormant when disabled so
+ * the queue disc reproduces vanilla behaviour exactly.
+ *
+ * Two parallel queue discs are run in lockstep: qA is default-constructed;
+ * qB sets EnableHostIsolation=false explicitly. Both receive the same
+ * 32-item enqueue sequence (alternating source IPs, shared destination)
+ * and are fully drained. The dispatched item sizes must match byte-for-byte
+ * across every dequeue step.
+ */
+class FqCobaltQueueDiscHostIsoOffByteIdentity : public TestCase
+{
+  public:
+    FqCobaltQueueDiscHostIsoOffByteIdentity();
+    ~FqCobaltQueueDiscHostIsoOffByteIdentity() override;
+
+  private:
+    void DoRun() override;
+};
+
+FqCobaltQueueDiscHostIsoOffByteIdentity::FqCobaltQueueDiscHostIsoOffByteIdentity()
+    : TestCase("Test EnableHostIsolation=false yields byte-identical dispatch vs default")
+{
+}
+
+FqCobaltQueueDiscHostIsoOffByteIdentity::~FqCobaltQueueDiscHostIsoOffByteIdentity()
+{
+}
+
+void
+FqCobaltQueueDiscHostIsoOffByteIdentity::DoRun()
+{
+    // qA: default-constructed (host isolation default is off).
+    Ptr<FqCobaltQueueDisc> qA = CreateObject<FqCobaltQueueDisc>();
+    qA->SetQuantum(1514);
+    qA->Initialize();
+
+    // qB: EnableHostIsolation explicitly false.
+    Ptr<FqCobaltQueueDisc> qB = CreateObjectWithAttributes<FqCobaltQueueDisc>(
+        "EnableHostIsolation",
+        BooleanValue(false));
+    qB->SetQuantum(1514);
+    qB->Initialize();
+
+    const Ipv4Address kSrcA("10.1.1.1");
+    const Ipv4Address kSrcB("10.1.1.2");
+    const Ipv4Address kDst("10.2.2.2");
+
+    // Enqueue 32 items alternating between two source IPs to the same
+    // destination. Both queue discs receive structurally-identical items
+    // (the helper synthesises fresh packets each call with the same payload
+    // size and header layout).
+    for (uint32_t i = 0; i < 32u; ++i)
+    {
+        const Ipv4Address& src = (i % 2 == 0) ? kSrcA : kSrcB;
+        qA->Enqueue(MakeIpv4HostHashItem(src, kDst));
+        qB->Enqueue(MakeIpv4HostHashItem(src, kDst));
+    }
+
+    // Dequeue all 32 items in lockstep and assert per-step byte-size equality.
+    for (uint32_t i = 0; i < 32u; ++i)
+    {
+        Ptr<QueueDiscItem> itemA = qA->Dequeue();
+        Ptr<QueueDiscItem> itemB = qB->Dequeue();
+        NS_TEST_ASSERT_MSG_NE(itemA, nullptr, "qA must return an item while non-empty");
+        NS_TEST_ASSERT_MSG_NE(itemB, nullptr, "qB must return an item while non-empty");
+        NS_TEST_ASSERT_MSG_EQ(itemA->GetSize(),
+                              itemB->GetSize(),
+                              "Dispatched item size must match byte-for-byte between default and host-iso-off");
+    }
+
+    // Both queue discs must be empty after the full drain.
+    NS_TEST_ASSERT_MSG_EQ(qA->Dequeue(), nullptr, "qA must be empty after draining 32 items");
+    NS_TEST_ASSERT_MSG_EQ(qB->Dequeue(), nullptr, "qB must be empty after draining 32 items");
+
+    Simulator::Destroy();
+}

From 74771cccb413fa7f3d78026c6cd652f4b1e9b2da Mon Sep 17 00:00:00 2001
From: Sergio Andreozzi <digitalities@gmail.com>
Date: Sat, 9 May 2026 13:45:05 +0200
Subject: [PATCH 3/8] traffic-control: Resolve QueueDisc::ChargeBytes
 auto-detect via NetDeviceQueueInterface::GetDevice

The auto-detect path in ChargeBytes resolves the L2 framing overhead
from the underlying NetDevice via NetDeviceQueueInterface::GetDevice
(added in the preceding commit on this MR). When the L2OverheadBytes
attribute is left at its default UINT32_MAX, ChargeBytes now reads
GetL2OverheadBytes() off the NetDevice the qdisc is attached to,
falling back to 0 if no NetDeviceQueueInterface is present (e.g. a
qdisc not yet attached to traffic control).

The four wire-byte-accounting consumers (FqCoDel, FqCobalt, FqPie,
Tbf) wire ChargeBytes in follow-up commits on this MR.

Assisted-by: Claude Code (Anthropic, claude-opus-4-7)
---
 src/traffic-control/model/queue-disc.cc | 19 +++++++++++++------
 1 file changed, 13 insertions(+), 6 deletions(-)

diff --git a/src/traffic-control/model/queue-disc.cc b/src/traffic-control/model/queue-disc.cc
index 848e3beb8..88e12dcfd 100644
--- a/src/traffic-control/model/queue-disc.cc
+++ b/src/traffic-control/model/queue-disc.cc
@@ -444,12 +444,19 @@ QueueDisc::GetNBytes() const
 uint32_t
 QueueDisc::ChargeBytes(Ptr<const QueueDiscItem> item) const
 {
-    // Auto-detect from m_devQueueIface->GetDevice() is pending a
-    // NetDeviceQueueInterface::GetDevice() accessor (follow-up commit
-    // on this MR). Until then, ChargeBytes resolves only the explicit
-    // L2OverheadBytes override; UINT32_MAX (default) means "no
-    // override, account in pure IP bytes".
-    uint32_t l2 = (m_l2OverheadOverride != UINT32_MAX) ? m_l2OverheadOverride : 0;
+    uint32_t l2 = 0;
+    if (m_l2OverheadOverride != UINT32_MAX)
+    {
+        l2 = m_l2OverheadOverride;
+    }
+    else if (m_devQueueIface)
+    {
+        Ptr<NetDevice> dev = m_devQueueIface->GetDevice();
+        if (dev)
+        {
+            l2 = dev->GetL2OverheadBytes();
+        }
+    }
     return item->GetSize() + l2;
 }
 
-- 

      */
     virtual uint32_t Hash(uint32_t perturbation = 0) const;
 
+    /**
+     * @brief Computes a hash derived from the packet's source-host identifier
+     *
+     * Used by queue discs that implement per-source-host fairness (such as
+     * CAKE's host-isolation modes). Subclasses with an L3 address should hash
+     * the source address (and only the source address) so that two packets
+     * sharing a source IP map to the same source-host bucket regardless of
+     * their destination or transport identifiers.
+     *
+     * This method just returns 0. Subclasses should implement a hash over the
+     * source-host identifier.
+     *
+     * @param perturbation hash perturbation value
+     * @return the hash of the source-host identifier
+     */
+    virtual uint32_t HashSrcHost(uint32_t perturbation = 0) const;
+
+    /**
+     * @brief Computes a hash derived from the packet's destination-host identifier
+     *
+     * Used by queue discs that implement per-destination-host fairness (such as
+     * CAKE's host-isolation modes). Subclasses with an L3 address should hash
+     * the destination address (and only the destination address) so that two
+     * packets sharing a destination IP map to the same destination-host bucket
+     * regardless of their source or transport identifiers.
+     *
+     * This method just returns 0. Subclasses should implement a hash over the
+     * destination-host identifier.
+     *
+     * @param perturbation hash perturbation value
+     * @return the hash of the destination-host identifier
+     */
+    virtual uint32_t HashDstHost(uint32_t perturbation = 0) const;
+
+    /**
+     * @brief Returns the L4 (transport) protocol number carried by the item.
+     *
+     * Used by queue discs that need to gate on transport-layer protocol
+     * without parsing the inner Packet's first bytes (e.g., to make
+     * TCP-only helpers self-defending when called from generic loops).
+     * This method just returns 0 (no transport context). Subclasses with
+     * an L3 header should return the protocol field directly (IPv4
+     * Protocol byte, IPv6 Next Header).
+     *
+     * @return the L4 protocol number (e.g., 6 for TCP, 17 for UDP, 0 if
+     *         the item carries no recoverable L3 context).
+     */
+    virtual uint8_t GetIpProtocol() const;
+
   private:
     Address m_address;   //!< MAC destination address
     uint16_t m_protocol; //!< L3 Protocol number

+     *
+     * Hashes the destination IPv4 address with the source address zeroed,
+     * concatenated with the perturbation value. This produces a
+     * per-destination-host bucket assignment for queue discs that implement
+     * destination-host fairness.
+     *
+     * @param perturbation hash perturbation value
+     * @return the hash of the destination-host identifier
+     */
+    uint32_t HashDstHost(uint32_t perturbation) const override;
+
+    /**
+     * @brief Returns the IPv4 Protocol field (RFC 791 §3.1).
+     *
+     * Overrides @c QueueDiscItem::GetIpProtocol to expose the L4 protocol
+     * number to traffic-control queue discs without requiring a link

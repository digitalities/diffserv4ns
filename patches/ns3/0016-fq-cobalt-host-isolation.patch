+uint32_t
+Ipv6QueueDiscItem::HashSrcHost(uint32_t perturbation) const
+{
+    NS_LOG_FUNCTION(this << perturbation);
+
+    Ipv6Address src = m_header.GetSource();
+
+    /* serialize (src, 0, perturbation) in buf — destination zeroed so that
+     * two packets sharing a source IPv6 map to the same source-host bucket. */
+    uint8_t buf[36] = {};
+    src.Serialize(buf);
+    // bytes 16..31 (destination) left zero by initializer
+    buf[32] = (perturbation >> 24) & 0xff;
+    buf[33] = (perturbation >> 16) & 0xff;
+    buf[34] = (perturbation >> 8) & 0xff;
+    buf[35] = perturbation & 0xff;
+
+    uint32_t hash = Hash32((char*)buf, 36);
+
+    // Map 0 to 1 to avoid collision with the empty-slot sentinel in the
+    // FqCobaltQueueDisc set-associative table (see Ipv4QueueDiscItem).
+    if (hash == 0u)
+    {
+        hash = 1u;
+    }
+
+    NS_LOG_DEBUG("HashSrcHost value " << hash);
+
+    return hash;
+}
+
+uint32_t
+Ipv6QueueDiscItem::HashDstHost(uint32_t perturbation) const
+{
+    NS_LOG_FUNCTION(this << perturbation);
+
+    Ipv6Address dst = m_header.GetDestination();
+
+    /* serialize (0, dst, perturbation) in buf — source zeroed so that two
+     * packets sharing a destination IPv6 map to the same dst-host bucket. */
+    uint8_t buf[36] = {};
+    // bytes 0..15 (source) left zero by initializer
+    dst.Serialize(buf + 16);
+    buf[32] = (perturbation >> 24) & 0xff;
+    buf[33] = (perturbation >> 16) & 0xff;
+    buf[34] = (perturbation >> 8) & 0xff;
+    buf[35] = perturbation & 0xff;
+
+    uint32_t hash = Hash32((char*)buf, 36);
+
+    if (hash == 0u)
+    {
+        hash = 1u;
+    }
+
+    NS_LOG_DEBUG("HashDstHost value " << hash);
+
+    return hash;
+}
+
 } // namespace ns3

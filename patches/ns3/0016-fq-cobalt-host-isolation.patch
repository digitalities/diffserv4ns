diff --git a/src/internet/model/ipv4-queue-disc-item.cc b/src/internet/model/ipv4-queue-disc-item.cc
index 852241d7c..75d701bdd 100644
--- a/src/internet/model/ipv4-queue-disc-item.cc
+++ b/src/internet/model/ipv4-queue-disc-item.cc
@@ -159,4 +159,81 @@ Ipv4QueueDiscItem::Hash(uint32_t perturbation) const
     return hash;
 }
 
+uint32_t
+Ipv4QueueDiscItem::HashSrcHost(uint32_t perturbation) const
+{
+    NS_LOG_FUNCTION(this << perturbation);
+
+    Ipv4Address src = m_header.GetSource();
+
+    /* serialize (src, 0, perturbation) in buf — destination zeroed so that
+     * two packets sharing a source IP map to the same source-host bucket. */
+    uint8_t buf[12] = {};
+    src.Serialize(buf);
+    // bytes 4..7 (destination) left zero by initializer
+    buf[8] = (perturbation >> 24) & 0xff;
+    buf[9] = (perturbation >> 16) & 0xff;
+    buf[10] = (perturbation >> 8) & 0xff;
+    buf[11] = perturbation & 0xff;
+
+    // Linux calculates jhash2 (jenkins hash), we calculate murmur3 because it is
+    // already available in ns-3
+    uint32_t hash = Hash32((char*)buf, 12);
+
+    // The FqCobaltQueueDisc set-associative table uses tag 0 as the empty-slot
+    // sentinel, so a Murmur3 collision with 0 would be indistinguishable from
+    // an unoccupied way. Map 0 to 1 here so every Ipv4 host-hash is non-zero;
+    // the probability of two distinct sources colliding at 1 is the same as
+    // any other pair, and the loss of one possible value (~2^-32 of the
+    // output range) is negligible.
+    if (hash == 0u)
+    {
+        hash = 1u;
+    }
+
+    NS_LOG_DEBUG("HashSrcHost value " << hash);
+
+    return hash;
+}
+
+uint32_t
+Ipv4QueueDiscItem::HashDstHost(uint32_t perturbation) const
+{
+    NS_LOG_FUNCTION(this << perturbation);
+
+    Ipv4Address dst = m_header.GetDestination();
+
+    /* serialize (0, dst, perturbation) in buf — source zeroed so that two
+     * packets sharing a destination IP map to the same destination-host
+     * bucket. */
+    uint8_t buf[12] = {};
+    // bytes 0..3 (source) left zero by initializer
+    dst.Serialize(buf + 4);
+    buf[8] = (perturbation >> 24) & 0xff;
+    buf[9] = (perturbation >> 16) & 0xff;
+    buf[10] = (perturbation >> 8) & 0xff;
+    buf[11] = perturbation & 0xff;
+
+    // Linux calculates jhash2 (jenkins hash), we calculate murmur3 because it is
+    // already available in ns-3
+    uint32_t hash = Hash32((char*)buf, 12);
+
+    // See HashSrcHost above: map 0 to 1 to avoid colliding with the
+    // empty-slot sentinel in the FqCobaltQueueDisc set-associative table.
+    if (hash == 0u)
+    {
+        hash = 1u;
+    }
+
+    NS_LOG_DEBUG("HashDstHost value " << hash);
+
+    return hash;
+}
+
+uint8_t
+Ipv4QueueDiscItem::GetIpProtocol() const
+{
+    return m_header.GetProtocol();
+}
+
 } // namespace ns3

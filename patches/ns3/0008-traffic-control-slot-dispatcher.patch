+++ b/src/traffic-control/model/slot-dispatcher.h
@@ -0,0 +1,202 @@
+/*
+ * Copyright (c) 2026 Sergio Andreozzi
+ *
+ * SPDX-License-Identifier: GPL-2.0-only
+ *
+ * Author: Sergio Andreozzi <digitalities@gmail.com>
+ */
+
+#ifndef SLOT_DISPATCHER_H
+#define SLOT_DISPATCHER_H
+
+#include "ns3/object.h"
+#include "ns3/ptr.h"
+
+#include <cstdint>
+
+namespace ns3
+{
+
+class QueueDisc;
+class QueueDiscItem;
+
+/**
+ * @ingroup traffic-control
+ *
+ * @brief Per-slot counter snapshot exposed by a SlotDispatcher.
+ *
+ * Wire-byte accumulators (matching QueueDiscItem::GetSize() semantics)
+ * plus drop and mark counters. Dispatchers that maintain per-slot state
+ * (deficit counters, rate-shaped tins, weighted accumulators) populate
+ * these fields. Stateless dispatchers (e.g. strict priority) return
+ * zeros.
+ */
+struct SlotDispatcherStats
+{
+    uint64_t bytesEnqueued{0}; //!< Total wire bytes admitted on this slot
+    uint64_t bytesDequeued{0}; //!< Total wire bytes drained from this slot
+    uint64_t drops{0};         //!< Drop count attributed to this slot
+    uint64_t marks{0};         //!< Mark count attributed to this slot
+};
+
+/**
+ * @ingroup traffic-control
+ *
+ * @brief Pluggable strategy that decides which child class of a
+ * multi-class queue disc is serviced on the next dequeue.
+ *
+ * A multi-class QueueDisc holds a list of QueueDiscClass children
+ * (accessed by GetNQueueDiscClasses() and GetQueueDiscClass(i)). The
+ * across-class dequeue policy (strict priority, weighted round-robin,
+ * deficit round-robin, rate-shaped) is the policy a SlotDispatcher
+ * implements.
+ *
+ * Subclasses override:
+ * - SelectDequeueSlot() to pick the slot to drain (may mutate
+ *   dispatcher state, e.g. advance a round-robin cursor or charge a
+ *   deficit counter)
+ * - PeekSlot() to pick the slot a subsequent dequeue would drain,
+ *   without mutating dispatcher state
+ * - OnEnqueue() to observe a successful enqueue (default no-op)
+ * - OnDequeue() to observe a successful dequeue (default no-op)
+ * - GetSlotStats() to expose per-slot counters (default returns zeros)
+ *
+ * The host queue disc is passed by Ptr<QueueDisc>, allowing the
+ * dispatcher to discover its children at call time. This keeps the
+ * abstraction independent of any specific multi-class queue disc.
+ */
+class SlotDispatcher : public Object
+{
+  public:
+    /**
+     * @brief Get the type ID.
+     * @return the object TypeId
+     */
+    static TypeId GetTypeId();
+
+    ~SlotDispatcher() override = default;
+
+    /**
+     * @brief Pick the populated slot to drain next.
+     *
+     * May mutate dispatcher state. Returns -1 if no child class is
+     * ready to yield a packet (all children empty, or none selected by
+     * the policy at this instant).
+     *
+     * @param parent the host queue disc whose children to consult
+     * @return slot index in [0, parent->GetNQueueDiscClasses()), or -1
+     *         if no slot is ready
+     */
+    virtual int32_t SelectDequeueSlot(Ptr<QueueDisc> parent) = 0;
+
+    /**
+     * @brief Pick the slot a subsequent dequeue would drain.
+     *
+     * MUST NOT mutate dispatcher state. The QueueDisc base
+     * infrastructure calls peek idempotently, so a mutating peek would
+     * desynchronise dispatcher state with the host's peek-then-dequeue
+     * sequence.
+     *
+     * @param parent the host queue disc whose children to consult
+     * @return slot index in [0, parent->GetNQueueDiscClasses()), or -1
+     *         if no slot is ready
+     */
+    virtual int32_t PeekSlot(Ptr<QueueDisc> parent) = 0;
+
+    /**
+     * @brief Notification fired after a successful enqueue into a child
+     * queue disc.
+     *
+     * Default: no-op. Stateful subclasses override to update bookkeeping
+     * (e.g. mark a slot as newly active, increment a per-slot counter).
+     *
+     * @param slot the slot that received the packet
+     * @param item the enqueued item
+     * @param parent the host queue disc
+     */
+    virtual void OnEnqueue(uint32_t /*slot*/,
+                           Ptr<QueueDiscItem> /*item*/,
+                           Ptr<QueueDisc> /*parent*/)
+    {
+    }
+
+    /**
+     * @brief Notification fired after a successful dequeue from a child
+     * queue disc.
+     *
+     * Default: no-op. Stateful subclasses override to update bookkeeping
+     * (e.g. decrement a deficit counter, advance a round-robin cursor,
+     * deactivate a slot that drained to empty).
+     *
+     * @param slot the slot that yielded the packet
+     * @param item the dequeued item
+     * @param parent the host queue disc
+     */
+    virtual void OnDequeue(uint32_t /*slot*/,
+                           Ptr<QueueDiscItem> /*item*/,
+                           Ptr<QueueDisc> /*parent*/)
+    {
+    }
+
+    /**
+     * @brief Read-only per-slot diagnostic snapshot.
+     *
+     * Default: returns a zeroed SlotDispatcherStats. Subclasses that
+     * track per-slot counters override; stateless subclasses leave the
+     * default in place.
+     *
+     * @param slotIdx the slot whose counters to return
+     * @param parent the host queue disc (may be inspected for
+     *        inner-queue accessors at call time)
+     * @return per-slot counters
+     */
+    virtual SlotDispatcherStats GetSlotStats(uint32_t /*slotIdx*/,
+                                             Ptr<const QueueDisc> /*parent*/) const
+    {
+        return SlotDispatcherStats{};
+    }
+};
+
+/**
+ * @ingroup traffic-control
+ *
+ * @brief Strict-priority slot dispatcher.
+ *
+ * Walks child classes in index order and returns the first whose inner
+ * queue disc reports a non-zero packet count. Higher-index slots are
+ * served only when all lower-index slots are empty. This is the policy
+ * embedded in PrioQueueDisc::DoDequeue, exposed here as a reusable
+ * strategy.
+ *
+ * Stateless: SelectDequeueSlot() and PeekSlot() share the walk;
+ * OnEnqueue() and OnDequeue() remain no-ops; GetSlotStats() returns
+ * zeros.
+ */
+class StrictPrioritySlotDispatcher : public SlotDispatcher
+{
+  public:
+    /**
+     * @brief Get the type ID.
+     * @return the object TypeId
+     */
+    static TypeId GetTypeId();
+
+    StrictPrioritySlotDispatcher() = default;
+
+    int32_t SelectDequeueSlot(Ptr<QueueDisc> parent) override;
+    int32_t PeekSlot(Ptr<QueueDisc> parent) override;
+
+  private:
+    /**
+     * @brief Walk children in index order; return the first slot whose
+     * inner queue disc reports GetNPackets() > 0, or -1.
+     *
+     * @param parent the host queue disc
+     * @return slot index of first non-empty child, or -1
+     */
+    int32_t FirstNonEmpty(Ptr<QueueDisc> parent) const;
+};
+
+} // namespace ns3
+
+#endif /* SLOT_DISPATCHER_H */

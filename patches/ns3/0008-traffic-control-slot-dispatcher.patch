+#include "slot-dispatcher.h"
+
+#include "queue-disc.h"
+
+#include "ns3/log.h"
+
+namespace ns3
+{
+
+NS_LOG_COMPONENT_DEFINE("SlotDispatcher");
+
+NS_OBJECT_ENSURE_REGISTERED(SlotDispatcher);
+
+TypeId
+SlotDispatcher::GetTypeId()
+{
+    NS_LOG_FUNCTION_NOARGS();
+    static TypeId tid =
+        TypeId("ns3::SlotDispatcher").SetParent<Object>().SetGroupName("TrafficControl");
+    return tid;
+}
+
+NS_OBJECT_ENSURE_REGISTERED(StrictPrioritySlotDispatcher);
+
+TypeId
+StrictPrioritySlotDispatcher::GetTypeId()
+{
+    NS_LOG_FUNCTION_NOARGS();
+    static TypeId tid = TypeId("ns3::StrictPrioritySlotDispatcher")
+                            .SetParent<SlotDispatcher>()
+                            .SetGroupName("TrafficControl")
+                            .AddConstructor<StrictPrioritySlotDispatcher>();
+    return tid;
+}
+
+int32_t
+StrictPrioritySlotDispatcher::SelectDequeueSlot(Ptr<QueueDisc> parent)
+{
+    NS_LOG_FUNCTION(this);
+    return FirstNonEmpty(parent);
+}
+
+int32_t
+StrictPrioritySlotDispatcher::PeekSlot(Ptr<QueueDisc> parent)
+{
+    NS_LOG_FUNCTION(this);
+    return FirstNonEmpty(parent);
+}
+
+int32_t
+StrictPrioritySlotDispatcher::FirstNonEmpty(Ptr<QueueDisc> parent) const
+{
+    NS_LOG_FUNCTION(this);
+    NS_ASSERT_MSG(parent, "StrictPrioritySlotDispatcher requires a non-null parent");
+    const std::size_t n = parent->GetNQueueDiscClasses();
+    for (std::size_t s = 0; s < n; ++s)
+    {
+        Ptr<QueueDisc> inner = parent->GetQueueDiscClass(s)->GetQueueDisc();
+        if (inner && inner->GetNPackets() > 0)
+        {
+            return static_cast<int32_t>(s);
+        }
+    }
+    return -1;
+}
+
+} // namespace ns3
diff --git a/src/traffic-control/model/slot-dispatcher.h b/src/traffic-control/model/slot-dispatcher.h

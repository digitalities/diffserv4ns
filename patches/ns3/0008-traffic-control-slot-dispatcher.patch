+ *
+ * Author: Sergio Andreozzi <digitalities@gmail.com>
+ */
+
+#include "ns3/fifo-queue-disc.h"
+#include "ns3/log.h"
+#include "ns3/packet.h"
+#include "ns3/prio-queue-disc.h"
+#include "ns3/queue-disc.h"
+#include "ns3/simulator.h"
+#include "ns3/slot-dispatcher.h"
+#include "ns3/socket.h"
+#include "ns3/string.h"
+#include "ns3/test.h"
+
+using namespace ns3;
+
+/**
+ * @ingroup traffic-control-test
+ *
+ * @brief Test item for the slot dispatcher test suite.
+ *
+ * Carries a SocketPriorityTag so that PrioQueueDisc's default priomap
+ * routes it to the band corresponding to its priority.
+ */
+class SlotDispatcherTestItem : public QueueDiscItem
+{
+  public:
+    /**
+     * Constructor.
+     *
+     * @param p the packet
+     * @param addr the address
+     * @param priority the packet priority
+     */
+    SlotDispatcherTestItem(Ptr<Packet> p, const Address& addr, uint8_t priority);
+    void AddHeader() override;
+    bool Mark() override;
+};
+
+SlotDispatcherTestItem::SlotDispatcherTestItem(Ptr<Packet> p, const Address& addr, uint8_t priority)
+    : QueueDiscItem(p, addr, 0)
+{
+    SocketPriorityTag priorityTag;
+    priorityTag.SetPriority(priority);
+    p->ReplacePacketTag(priorityTag);
+}
+
+void
+SlotDispatcherTestItem::AddHeader()
+{
+}
+
+bool
+SlotDispatcherTestItem::Mark()
+{
+    return false;
+}
+
+/**
+ * @ingroup traffic-control-test
+ *
+ * @brief Build a PrioQueueDisc with @p nBands child FifoQueueDisc
+ * classes, set an identity priomap so packet priority p maps to band p
+ * (for p in 0..min(nBands-1, 15)), and run Initialize().
+ *
+ * @param nBands the number of child classes to attach (>= 2)
+ * @return the initialised PrioQueueDisc
+ */
+static Ptr<PrioQueueDisc>
+BuildPrioHost(uint32_t nBands)
+{
+    Ptr<PrioQueueDisc> qdisc = CreateObject<PrioQueueDisc>();
+    // Identity priomap clamped to nBands - 1 for priorities >= nBands.
+    std::string priomap;
+    for (uint16_t p = 0; p < 16; ++p)
+    {
+        if (p > 0)
+        {
+            priomap += " ";
+        }
+        const uint16_t band = (p < nBands) ? p : (nBands - 1);
+        priomap += std::to_string(band);
+    }
+    qdisc->SetAttribute("Priomap", StringValue(priomap));
+    for (uint32_t i = 0; i < nBands; ++i)
+    {
+        Ptr<FifoQueueDisc> child = CreateObject<FifoQueueDisc>();
+        child->Initialize();
+        Ptr<QueueDiscClass> c = CreateObject<QueueDiscClass>();
+        c->SetQueueDisc(child);
+        qdisc->AddQueueDiscClass(c);
+    }
+    qdisc->Initialize();
+    return qdisc;
+}
+
+/**
+ * @ingroup traffic-control-test
+ *
+ * @brief Empty host returns -1 from SelectDequeueSlot and PeekSlot.
+ */
+class SlotDispatcherEmptyHostTestCase : public TestCase
+{
+  public:
+    SlotDispatcherEmptyHostTestCase()
+        : TestCase("Empty multi-class host returns -1")
+    {
+    }
+
+    void DoRun() override
+    {
+        Ptr<PrioQueueDisc> host = BuildPrioHost(4);
+        StrictPrioritySlotDispatcher dispatcher;
+
+        NS_TEST_ASSERT_MSG_EQ(dispatcher.SelectDequeueSlot(host),
+                              -1,
+                              "Empty host: SelectDequeueSlot must return -1");
+        NS_TEST_ASSERT_MSG_EQ(dispatcher.PeekSlot(host), -1, "Empty host: PeekSlot must return -1");
+
+        Simulator::Destroy();
+    }
+};
+
+/**
+ * @ingroup traffic-control-test
+ *
+ * @brief Strict priority: lowest non-empty slot is preferred.
+ *
+ * Enqueue first into the slot-2 child, then verify the dispatcher
+ * returns 2; enqueue into slot-1, expect 1; enqueue into slot-0,
+ * expect 0. After draining slot-0 (one packet), expect 1, then 2.
+ */
+class SlotDispatcherStrictPriorityTestCase : public TestCase
+{
+  public:
+    SlotDispatcherStrictPriorityTestCase()
+        : TestCase("Strict priority preference: lowest non-empty slot wins")
+    {
+    }
+
+    void DoRun() override
+    {
+        Ptr<PrioQueueDisc> host = BuildPrioHost(4);
+        StrictPrioritySlotDispatcher dispatcher;
+        Address dest;
+
+        // Enqueue into slot 2 first
+        host->Enqueue(Create<SlotDispatcherTestItem>(Create<Packet>(100), dest, 2));
+        NS_TEST_ASSERT_MSG_EQ(dispatcher.SelectDequeueSlot(host),
+                              2,
+                              "Only slot 2 populated: must return 2");
+
+        // Enqueue into slot 1 — strict priority now prefers 1
+        host->Enqueue(Create<SlotDispatcherTestItem>(Create<Packet>(100), dest, 1));
+        NS_TEST_ASSERT_MSG_EQ(dispatcher.SelectDequeueSlot(host),
+                              1,
+                              "Slots 1 and 2 populated: must prefer 1");
+
+        // Enqueue into slot 0 — strict priority now prefers 0
+        host->Enqueue(Create<SlotDispatcherTestItem>(Create<Packet>(100), dest, 0));
+        NS_TEST_ASSERT_MSG_EQ(dispatcher.SelectDequeueSlot(host),
+                              0,
+                              "Slots 0, 1, 2 populated: must prefer 0");
+
+        // Drain via the host's Dequeue (slot 0 yields, becomes empty)
+        Ptr<QueueDiscItem> first = host->Dequeue();
+        NS_TEST_ASSERT_MSG_NE(first, nullptr, "Host must yield the slot-0 packet");
+        NS_TEST_ASSERT_MSG_EQ(dispatcher.SelectDequeueSlot(host),
+                              1,
+                              "Slot 0 drained: must now prefer 1");
+
+        // Drain slot 1, expect 2 next
+        Ptr<QueueDiscItem> second = host->Dequeue();
+        NS_TEST_ASSERT_MSG_NE(second, nullptr, "Host must yield the slot-1 packet");
+        NS_TEST_ASSERT_MSG_EQ(dispatcher.SelectDequeueSlot(host),
+                              2,
+                              "Slot 1 drained: must now prefer 2");
+
+        Simulator::Destroy();
+    }
+};
+
+/**
+ * @ingroup traffic-control-test
+ *
+ * @brief PeekSlot is side-effect free: repeated calls return the same
+ * slot, and host packet counts are unchanged.
+ */
+class SlotDispatcherPeekIdempotentTestCase : public TestCase
+{
+  public:
+    SlotDispatcherPeekIdempotentTestCase()
+        : TestCase("PeekSlot is side-effect free under repeated calls")
+    {
+    }
+
+    void DoRun() override
+    {
+        Ptr<PrioQueueDisc> host = BuildPrioHost(3);
+        StrictPrioritySlotDispatcher dispatcher;
+        Address dest;
+
+        // Enqueue 2 into slot 1 and 1 into slot 2
+        host->Enqueue(Create<SlotDispatcherTestItem>(Create<Packet>(100), dest, 1));
+        host->Enqueue(Create<SlotDispatcherTestItem>(Create<Packet>(100), dest, 1));
+        host->Enqueue(Create<SlotDispatcherTestItem>(Create<Packet>(100), dest, 2));
+
+        const uint32_t before1 = host->GetQueueDiscClass(1)->GetQueueDisc()->GetNPackets();
+        const uint32_t before2 = host->GetQueueDiscClass(2)->GetQueueDisc()->GetNPackets();
+
+        const int32_t peek1 = dispatcher.PeekSlot(host);
+        const int32_t peek2 = dispatcher.PeekSlot(host);
+        const int32_t peek3 = dispatcher.PeekSlot(host);
+
+        NS_TEST_ASSERT_MSG_EQ(peek1, 1, "First peek must return slot 1");
+        NS_TEST_ASSERT_MSG_EQ(peek2, peek1, "Second peek must equal first");
+        NS_TEST_ASSERT_MSG_EQ(peek3, peek1, "Third peek must equal first");
+
+        const uint32_t after1 = host->GetQueueDiscClass(1)->GetQueueDisc()->GetNPackets();
+        const uint32_t after2 = host->GetQueueDiscClass(2)->GetQueueDisc()->GetNPackets();
+        NS_TEST_ASSERT_MSG_EQ(after1, before1, "Slot 1 count must be unchanged after peeks");
+        NS_TEST_ASSERT_MSG_EQ(after2, before2, "Slot 2 count must be unchanged after peeks");
+
+        // Default GetSlotStats returns zeros for the stateless subclass
+        SlotDispatcherStats stats = dispatcher.GetSlotStats(0, host);
+        NS_TEST_ASSERT_MSG_EQ(stats.bytesEnqueued, 0u, "Default stats: bytesEnqueued zero");
+        NS_TEST_ASSERT_MSG_EQ(stats.bytesDequeued, 0u, "Default stats: bytesDequeued zero");
+        NS_TEST_ASSERT_MSG_EQ(stats.drops, 0u, "Default stats: drops zero");
+        NS_TEST_ASSERT_MSG_EQ(stats.marks, 0u, "Default stats: marks zero");
+
+        Simulator::Destroy();
+    }
+};
+
+/**
+ * @ingroup traffic-control-test
+ *
+ * @brief Slot Dispatcher Test Suite.
+ */
+static class SlotDispatcherTestSuite : public TestSuite
+{
+  public:
+    SlotDispatcherTestSuite()
+        : TestSuite("slot-dispatcher", Type::UNIT)
+    {
+        AddTestCase(new SlotDispatcherEmptyHostTestCase(), TestCase::Duration::QUICK);
+        AddTestCase(new SlotDispatcherStrictPriorityTestCase(), TestCase::Duration::QUICK);
+        AddTestCase(new SlotDispatcherPeekIdempotentTestCase(), TestCase::Duration::QUICK);
+    }
+} g_slotDispatcherTestSuite; //!< Static variable for test initialization

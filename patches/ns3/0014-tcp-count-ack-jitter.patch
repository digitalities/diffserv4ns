+/* Send an immediate ACK on count-threshold fire, optionally jittered. */
+void
+TcpSocketBase::SendImmediateAckMaybeJittered(uint8_t flags)
+{
+    if (m_enableCountAckJitter && m_countAckJitterMaxUs > 0)
+    {
+        if (!m_countAckJitterRng)
+        {
+            m_countAckJitterRng = CreateObject<UniformRandomVariable>();
+        }
+        uint32_t jitterUs =
+            m_countAckJitterRng->GetInteger(0, m_countAckJitterMaxUs);
+        Simulator::Schedule(MicroSeconds(jitterUs),
+                            &TcpSocketBase::SendEmptyPacket,
+                            this, flags);
+    }
+    else
+    {
+        SendEmptyPacket(flags);
+    }
+}

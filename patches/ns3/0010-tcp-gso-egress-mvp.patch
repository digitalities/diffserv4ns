new file mode 100644
index 000000000..9197de59c
--- /dev/null
+++ b/src/internet/model/tcp-gso-segmenter.h
@@ -0,0 +1,50 @@
+/*
+ * SPDX-License-Identifier: GPL-2.0-only
+ */
+#ifndef TCP_GSO_SEGMENTER_H
+#define TCP_GSO_SEGMENTER_H
+
+#include "ns3/ptr.h"
+
+namespace ns3
+{
+
+class NetDevice;
+class QueueDiscItem;
+
+/**
+ * \ingroup tcp
+ *
+ * \brief TCP-aware re-segmentation of a GSO super-segment, called by the
+ *        Traffic Control egress hook via the registered GsoSegmenter callback.
+ *
+ * The function inspects the QueueDiscItem for a TcpGsoOriginTag. If absent,
+ * it returns false and the caller forwards the item unchanged to
+ * `NetDevice::Send`. If present, the function:
+ *
+ *  - dynamic-casts the item to `Ipv4QueueDiscItem` (asserts on failure);
+ *  - removes the IPv4 and TCP headers from the packet bytes (they were
+ *    serialized into the packet by `QueueDisc::Dequeue` via
+ *    `Ipv4QueueDiscItem::AddHeader`);
+ *  - splits the remaining payload into `segCount` fragments of `mssSize`
+ *    bytes (last fragment may be shorter);
+ *  - clones the TCP header for each fragment (sequence number advanced by
+ *    `mssSize`; FIN and PSH bits cleared on all but the last fragment;
+ *    other flags inherited unchanged);
+ *  - clones the IPv4 header for each fragment (total length adjusted);
+ *  - recomputes both checksums via the standard ns-3 header machinery;
+ *  - emits each MTU-sized fragment to `NetDevice::Send`.
+ *
+ * The receiver TCP stack sees N valid TCP segments with monotonically
+ * advancing sequence numbers, matching the wire-side behavior of Linux's
+ * `dev_queue_xmit` → `skb_segment` path after the qdisc has counted the
+ * super-skb as one arrival.
+ *
+ * Returns true if the function consumed the item (segmented + emitted).
+ * Returns false if the item is not a GSO super-segment.
+ */
+bool TcpGsoSegment(Ptr<NetDevice> device, Ptr<QueueDiscItem> item);
+
+} // namespace ns3
+
+#endif /* TCP_GSO_SEGMENTER_H */

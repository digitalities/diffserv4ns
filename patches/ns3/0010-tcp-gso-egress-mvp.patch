+/*
+ * SPDX-License-Identifier: GPL-2.0-only
+ */
+#include "tcp-gso-origin-tag.h"
+
+namespace ns3
+{
+
+NS_OBJECT_ENSURE_REGISTERED(TcpGsoOriginTag);
+
+TcpGsoOriginTag::TcpGsoOriginTag() = default;
+
+TcpGsoOriginTag::TcpGsoOriginTag(uint16_t mssSize, uint16_t segCount)
+    : m_mssSize(mssSize),
+      m_segCount(segCount)
+{
+}
+
+TypeId
+TcpGsoOriginTag::GetTypeId()
+{
+    static TypeId tid = TypeId("ns3::TcpGsoOriginTag")
+                            .SetParent<Tag>()
+                            .SetGroupName("Internet")
+                            .AddConstructor<TcpGsoOriginTag>();
+    return tid;
+}
+
+TypeId
+TcpGsoOriginTag::GetInstanceTypeId() const
+{
+    return GetTypeId();
+}
+
+uint32_t
+TcpGsoOriginTag::GetSerializedSize() const
+{
+    return 4;
+}
+
+void
+TcpGsoOriginTag::Serialize(TagBuffer i) const
+{
+    i.WriteU16(m_mssSize);
+    i.WriteU16(m_segCount);
+}
+
+void
+TcpGsoOriginTag::Deserialize(TagBuffer i)
+{
+    m_mssSize = i.ReadU16();
+    m_segCount = i.ReadU16();
+}
+
+void
+TcpGsoOriginTag::Print(std::ostream& os) const
+{
+    os << "mssSize=" << m_mssSize << " segCount=" << m_segCount;
+}
+
+uint16_t
+TcpGsoOriginTag::GetMssSize() const
+{
+    return m_mssSize;
+}
+
+uint16_t
+TcpGsoOriginTag::GetSegCount() const
+{
+    return m_segCount;
+}
+
+} // namespace ns3
diff --git a/src/internet/model/tcp-gso-origin-tag.h b/src/internet/model/tcp-gso-origin-tag.h
new file mode 100644
index 000000000..0c5ae7cab
--- /dev/null
+++ b/src/internet/model/tcp-gso-origin-tag.h
@@ -0,0 +1,78 @@
+/*
+ * SPDX-License-Identifier: GPL-2.0-only
+ */
+#ifndef TCP_GSO_ORIGIN_TAG_H
+#define TCP_GSO_ORIGIN_TAG_H
+
+#include "ns3/tag.h"
+
+namespace ns3
+{
+
+/**
+ * \ingroup tcp
+ *
+ * \brief Packet tag identifying a super-segment emitted by TcpSocketBase
+ *        under Generic Segmentation Offload.
+ *
+ * When TcpSocketBase has EnableGso=true and emits a super-segment of up to
+ * MaxGsoSize bytes, it attaches this tag carrying the per-segment MSS and
+ * the count of MSS-sized fragments to be produced at the egress hook.
+ *
+ * The tag is consumed by TrafficControlLayer just before NetDevice::Send:
+ * the layer parses the IPv4 and TCP headers from the super-segment, clones
+ * for each of the SegCount fragments (sequence number advanced by
+ * MssSize per fragment, FIN/PSH only on the last), recomputes the IPv4
+ * and TCP checksums, and emits MTU-sized packets to the underlying device.
+ *
+ * The qdisc, on the other hand, sees the super-segment intact: this is
+ * the observable semantics of Linux TSO/GSO at the qdisc/device boundary,
+ * where dev_queue_xmit segments the sk_buff after the qdisc has counted
+ * it as one arrival.
+ */
+class TcpGsoOriginTag : public Tag
+{
+  public:
+    /**
+     * \brief Default constructor.
+     */
+    TcpGsoOriginTag();
+
+    /**
+     * \brief Constructor.
+     *
+     * \param mssSize MSS-sized fragment payload bytes (typically the socket's segment size).
+     * \param segCount Number of MSS-sized fragments to produce at egress.
+     */
+    TcpGsoOriginTag(uint16_t mssSize, uint16_t segCount);
+
+    /**
+     * \brief Get the TypeId.
+     * \return The object TypeId.
+     */
+    static TypeId GetTypeId();
+
+    TypeId GetInstanceTypeId() const override;
+    uint32_t GetSerializedSize() const override;
+    void Serialize(TagBuffer i) const override;
+    void Deserialize(TagBuffer i) override;
+    void Print(std::ostream& os) const override;
+
+    /**
+     * \return MSS-sized fragment payload bytes.
+     */
+    uint16_t GetMssSize() const;
+
+    /**
+     * \return Count of MSS-sized fragments the egress hook should produce.
+     */
+    uint16_t GetSegCount() const;
+
+  private:
+    uint16_t m_mssSize{0};  //!< MSS-sized fragment payload bytes.
+    uint16_t m_segCount{0}; //!< Count of MSS-sized fragments.
+};
+
+} // namespace ns3
+
+#endif /* TCP_GSO_ORIGIN_TAG_H */
diff --git a/src/internet/model/tcp-gso-segmenter.cc b/src/internet/model/tcp-gso-segmenter.cc
new file mode 100644
index 000000000..1bea61ff8
--- /dev/null
+++ b/src/internet/model/tcp-gso-segmenter.cc
@@ -0,0 +1,113 @@
+/*
+ * SPDX-License-Identifier: GPL-2.0-only
+ */
+#include "tcp-gso-segmenter.h"
+
+#include "ipv4-header.h"
+#include "ipv4-queue-disc-item.h"
+#include "tcp-gso-origin-tag.h"
+#include "tcp-header.h"
+
+#include "ns3/log.h"
+#include "ns3/net-device.h"
+#include "ns3/packet.h"
+#include "ns3/traffic-control-layer.h"
+
+namespace ns3
+{
+
+NS_LOG_COMPONENT_DEFINE("TcpGsoSegmenter");
+
+bool
+TcpGsoSegment(Ptr<NetDevice> device, Ptr<QueueDiscItem> item)
+{
+    NS_LOG_FUNCTION(device << item);
+
+    Ptr<Packet> packet = item->GetPacket();
+    TcpGsoOriginTag gsoTag;
+    if (!packet->PeekPacketTag(gsoTag))
+    {
+        return false;
+    }
+
+    Ptr<Ipv4QueueDiscItem> ipItem = DynamicCast<Ipv4QueueDiscItem>(item);
+    NS_ASSERT_MSG(ipItem, "GSO supported only for Ipv4QueueDiscItem");
+
+    Ipv4Header origIp;
+    TcpHeader origTcp;
+    // Packet currently has [Ipv4 hdr][TCP hdr][payload].
+    // QueueDisc::Dequeue called item->AddHeader() before reaching the egress
+    // callback, so the IPv4 header is at the front of the byte stream.
+    packet->RemoveHeader(origIp);
+    packet->RemoveHeader(origTcp);
+    packet->RemovePacketTag(gsoTag);
+
+    const uint16_t mssSize = gsoTag.GetMssSize();
+    const uint16_t segCount = gsoTag.GetSegCount();
+    const SequenceNumber32 origSeq = origTcp.GetSequenceNumber();
+    const uint8_t origFlags = origTcp.GetFlags();
+    const uint32_t totalPayload = packet->GetSize();
+
+    NS_ASSERT_MSG(totalPayload > 0, "GSO super-segment has zero payload");
+    NS_LOG_DEBUG("GSO segmenting payload=" << totalPayload << " mss=" << mssSize
+                                            << " segCount=" << segCount);
+
+    uint32_t consumed = 0;
+    for (uint16_t i = 0; i < segCount; ++i)
+    {
+        const uint32_t fragSize = std::min<uint32_t>(mssSize, totalPayload - consumed);
+        if (fragSize == 0)
+        {
+            break;
+        }
+        Ptr<Packet> fragPayload = packet->CreateFragment(consumed, fragSize);
+        consumed += fragSize;
+
+        // Copy-construct from the original TCP header to preserve options
+        // (timestamps, SACK-permitted, window-scale, etc.). Then adjust the
+        // sequence number, FIN/PSH flags, and recompute the checksum.
+        TcpHeader segTcp = origTcp;
+        segTcp.SetSequenceNumber(origSeq + i * mssSize);
+        uint8_t segFlags = origFlags;
+        if (i < segCount - 1)
+        {
+            segFlags &= ~(static_cast<uint8_t>(TcpHeader::FIN) |
+                          static_cast<uint8_t>(TcpHeader::PSH));
+        }
+        segTcp.SetFlags(segFlags);
+        segTcp.InitializeChecksum(origIp.GetSource(), origIp.GetDestination(), 6 /* TCP */);
+        segTcp.EnableChecksums();
+
+        Ipv4Header segIp = origIp;
+        segIp.SetPayloadSize(segTcp.GetSerializedSize() + fragSize);
+
+        Ptr<Packet> segPacket = fragPayload->Copy();
+        segPacket->AddHeader(segTcp);
+
+        Ptr<Ipv4QueueDiscItem> segItem =
+            Create<Ipv4QueueDiscItem>(segPacket, item->GetAddress(), 0x0800, segIp);
+        segItem->AddHeader();
+        device->Send(segItem->GetPacket(), segItem->GetAddress(), segItem->GetProtocol());
+    }
+    return true;
+}
+
+namespace
+{
+/**
+ * Register the TCP GSO segmenter with the Traffic Control layer at
+ * static-init time. The internet library is linked into any binary
+ * that exercises TCP, so this registration runs once per process.
+ */
+struct TcpGsoSegmenterRegistrar
+{
+    TcpGsoSegmenterRegistrar()
+    {
+        TrafficControlLayer::RegisterGsoSegmenter(MakeCallback(&TcpGsoSegment));
+    }
+};
+
+static TcpGsoSegmenterRegistrar s_tcpGsoSegmenterRegistrar;
+} // namespace
+
+} // namespace ns3
